<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

  <t t-name="fashion_forecast.Dashboard" owl="1">
    <div class="fashion_forecast_dashboard p-3 o_action">

            <!-- HEADER -->
      <div class="ff_header">
        <div class="ff_header_left">
          <div class="ff_title_block">
            <div class="ff_title">DỰ BÁO NHU CẦU</div>
            <div class="ff_subtitle">
              Dự báo số lượng nhu cầu theo sản phẩm, thời gian và kịch bản để phục vụ kế hoạch cung ứng ngành thời trang
            </div>
          </div>
        </div>

        <div class="ff_header_right mt-3">
          <div class="ff_header_actions d-flex gap-2 align-items-center">
            <div class="dropdown">
              <button class="btn ff_pill dropdown-toggle" data-bs-toggle="dropdown" type="button">
                <i class="fa fa-calendar-o me-1"/>
                Tháng
              </button>
              <div class="dropdown-menu">
                <a class="dropdown-item" href="#">Tháng này</a>
                <a class="dropdown-item" href="#">Tháng sau</a>
              </div>
            </div>

                        <!-- nếu muốn gọi RPC thì đổi thành: t-on-click="load" -->
            <button class="btn btn-primary" type="button">
              Làm mới dự báo
            </button>
          </div>
        </div>
      </div>

            <!-- FILTERS (center) -->
      <div class="d-flex justify-content-center align-items-center mt-3">
        <div class="ff_filter_group d-flex gap-2">
          <div class="dropdown">
            <button class="btn ff_pill dropdown-toggle" data-bs-toggle="dropdown" type="button">
              <span class="ff_dot"/>
              Thời trang nữ
            </button>
            <div class="dropdown-menu">
              <a class="dropdown-item" href="#">Thời trang nữ</a>
              <a class="dropdown-item" href="#">Thời trang nam</a>
            </div>
          </div>

          <div class="dropdown">
            <button class="btn ff_pill dropdown-toggle" data-bs-toggle="dropdown" type="button">
              <i class="fa fa-user-o me-1"/>
              Nhóm SKU / SKU
            </button>
            <div class="dropdown-menu">
              <a class="dropdown-item" href="#">Nhóm SKU</a>
              <a class="dropdown-item" href="#">SKU</a>
            </div>
          </div>

          <div class="dropdown">
            <button class="btn ff_pill dropdown-toggle" data-bs-toggle="dropdown" type="button">
              Tháng
            </button>
            <div class="dropdown-menu">
              <a class="dropdown-item" href="#">Tháng</a>
              <a class="dropdown-item" href="#">Tuần</a>
              <a class="dropdown-item" href="#">Quý</a>
            </div>
          </div>
        </div>
      </div>

            <!-- BODY -->
      <div class="mt-3">
        <t t-if="state.loading"><div class="alert alert-info">Đang tải dữ liệu...</div></t><t t-elif="state.error"><div class="alert alert-danger"><t t-esc="state.error"/></div></t><t t-else="">

                    <!-- KPI cards -->
          <div class="row g-3 mb-3">
            <div class="col-12 col-md-3">
              <div class="card p-3 h-100">
                <h3 class="mb-2">Nhu Cầu Dự Báo</h3>
                <div class="fs-4 fw-bold">
                  <t t-esc="formatNumber(state.kpis.sku_forecast)"/>
                </div>
                <div class="small">
                  <span class="text-success"><t t-esc="state.kpis.delta_percent"/></span>
                  <span class="text-muted"> so với kỳ trước</span>
                </div>
              </div>
            </div>

            <div class="col-12 col-md-3">
              <div class="card p-3 h-100">
                <h3 class="mb-2">SKU Nhu Cầu Cao Nhất</h3>
                <div class="fs-6 fw-bold"><t t-esc="state.kpis.top_sku_name"/></div>
                <div class="small text-muted">
                  <t t-esc="state.kpis.top_sku_share"/> tổng nhu cầu
                </div>
              </div>
            </div>

            <div class="col-12 col-md-3">
              <div class="card p-3 h-100">
                <h3 class="mb-2">Nguy Cơ Thiếu Hàng</h3>
                <div class="fs-4 fw-bold">
                  <t t-esc="formatNumber(state.kpis.low_stock_sku_count)"/> SKU
                </div>
                <div class="small text-muted"><t t-esc="state.kpis.low_stock_hint"/></div>
              </div>
            </div>

            <div class="col-12 col-md-3">
              <div class="card p-3 h-100">
                <h3 class="mb-2">Đã Điều Chỉnh Thủ Công</h3>
                <div class="fs-4 fw-bold">
                  <t t-esc="state.kpis.manual_adjusted ? 'Có' : 'Không'"/>
                </div>
                <div class="small text-muted">
                  Lần cập nhật: <t t-esc="state.kpis.last_update || '-'"/>
                </div>
              </div>
            </div>
          </div>

                    <!-- Chart + Adjustment -->
          <div class="row g-3 mb-3">
            <div class="col-12 col-lg-8">
                <div class="card p-3 h-100">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                    <h5 class="mb-0">Dự báo nhu cầu theo thời gian</h5>
                    <div class="d-flex gap-2 align-items-center">
                        <span class="text-muted small">Tháng</span>
                        <span class="badge bg-success">Tuần</span>
                        <span class="text-muted small">Quý</span>
                    </div>
                    </div>

                                <!-- chart -->
                    <div class="position-relative" style="height: 280px;">
                    <canvas t-ref="forecastChart"/>
                    </div>
                </div>
            </div>
             <div class="col-12 col-lg-4">
                <div class="card p-3 h-100 d-flex flex-column">
                    <h5 class="mb-3">
                        Dự báo nhu cầu theo SKU
                    </h5>
                    <div class="table-responsive">
                        <table class="table table-sm align-middle mb-0">
                        <thead class="text-muted">
                            <tr>
                            <th>SKU</th>
                            <th class="text-end">Danh Mục</th>
                            <th class="text-end">Nhu Cầu</th>
                            <th class="text-end">Thực Tế</th>
                            </tr>
                        </thead>

                        <tbody>
                            <t t-if="!state.forecast_rows.length">
                            <tr>
                                <td colspan="4" class="text-muted">Chưa có dữ liệu</td>
                            </tr>
                            </t><t t-else="">
                            <t t-foreach="state.forecast_rows" t-as="row" t-key="row.key">
                                <tr>
                                <td class="fw-semibold"><t t-esc="row.name"/></td>
                                <td class="text-end"><t t-esc="row.category"/></td>
                                <td class="text-end"><t t-esc="formatNumber(row.demand)"/></td>
                                <td class="text-end">
                                    <span class="badge bg-light text-dark">
                                    <t t-esc="formatNumber(row.actual)"/>
                                    </span>
                                </td>
                                </tr>
                            </t>
                            </t>
                        </tbody>
                        </table>
                    </div>
                    <div class="mt-5">
                        <button class="btn btn-primary">
                            Xem Chi Tiết
                        </button>
                    </div>
                </div>
            </div>
        </div>
        <!-- TABLES -->
          <div class="row g-3">
                        <!-- LEFT (2 tables) -->
            <div class="col-12 col-lg-8">
              <div class="row g-3">

                <!-- Table 1 -->
                <div class="col-12 col-md-6">
                  <div class="card h-100 mb-3 p-3">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                      <h5 class="mb-0">Dự báo theo SKU</h5>
                      <span class="text-muted small">Top</span>
                    </div>

                    <div class="table-responsive">
                      <table class="table table-sm align-middle mb-0">
                        <thead class="text-muted">
                          <tr>
                            <th>SKU</th>
                            <th class="text-end">Danh Mục</th>
                            <th class="text-end">Nhu Cầu</th>
                            <th class="text-end">Thực Tế</th>
                          </tr>
                        </thead>

                        <tbody>
                          <t t-if="!state.forecast_rows.length">
                            <tr>
                              <td colspan="4" class="text-muted">Chưa có dữ liệu</td>
                            </tr>
                          </t><t t-else="">
                            <t t-foreach="state.forecast_rows" t-as="row" t-key="row.key">
                              <tr>
                                <td class="fw-semibold"><t t-esc="row.name"/></td>
                                <td class="text-end"><t t-esc="row.category"/></td>
                                <td class="text-end"><t t-esc="formatNumber(row.demand)"/></td>
                                <td class="text-end">
                                  <span class="badge bg-light text-dark">
                                    <t t-esc="formatNumber(row.actual)"/>
                                  </span>
                                </td>
                              </tr>
                            </t>
                          </t>
                        </tbody>
                      </table>
                    </div>
                  </div>
                </div>

                                <!-- Table 2 -->
                <div class="col-12 col-md-6">
                  <div class="card h-100 mb-3 p-3">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                      <h5 class="mb-0">Nguy cơ thiếu hàng</h5>
                      <span class="text-muted small">7 ngày</span>
                    </div>

                    <div class="table-responsive">
                      <table class="table table-sm align-middle mb-0">
                        <thead class="text-muted">
                          <tr>
                            <th>SKU</th>
                            <th class="text-end">Thiếu</th>
                            <th class="text-end">Nhu Cầu</th>
                            <th class="text-end">Thực Tế</th>
                          </tr>
                        </thead>

                        <tbody>
                          <t t-if="!state.forecast_leak_rows.length">
                            <tr>
                              <td colspan="4" class="text-muted">Chưa có dữ liệu</td>
                            </tr>
                          </t><t t-else="">
                            <t t-foreach="state.forecast_leak_rows" t-as="row" t-key="row.key + '_risk'">
                              <tr>
                                <td class="fw-semibold"><t t-esc="row.name"/></td>
                                <td class="text-end">
                                  <span class="badge bg-warning text-dark">
                                    -<t t-esc="formatNumber(row.need)"/>
                                  </span>
                                </td>
                                <td class="text-end"><t t-esc="formatNumber(row.demand)"/></td>
                                <td class="text-end">
                                  <span class="badge bg-light text-dark">
                                    <t t-esc="formatNumber(row.actual)"/>
                                  </span>
                                </td>
                              </tr>
                            </t>
                          </t>
                        </tbody>
                      </table>
                    </div>
                  </div>
                </div>

              </div>
            </div>

                        <!-- RIGHT (Usage card) -->
            <div class="col-12 col-lg-4">
              <div class="card h-100 mb-3 p-4">
                <div class="d-flex justify-content-between align-items-start mb-3">
                  <h5 class="mb-0 fw-bold">Sử dụng kết quả dự báo cho:</h5>
                  <i class="fa fa-ellipsis-h text-muted"/>
                </div>

                <div class="d-flex flex-column gap-3 mt-3">
                  <div class="d-flex align-items-center gap-3">
                    <span class="d-inline-flex align-items-center justify-content-center rounded-3 bg-light"
                          style="width:36px;height:36px;">
                      <i class="fa fa-briefcase text-success"/>
                    </span>
                    <span class="fw-semibold">Lập kế hoạch đặt hàng</span>
                  </div>

                  <div class="d-flex align-items-center gap-3">
                    <span class="d-inline-flex align-items-center justify-content-center rounded-3 bg-light"
                          style="width:36px;height:36px;">
                      <i class="fa fa-industry text-success"/>
                    </span>
                    <span class="fw-semibold">Lập kế hoạch sản xuất</span>
                  </div>

                  <div class="d-flex align-items-center gap-3">
                    <span class="d-inline-flex align-items-center justify-content-center rounded-3 bg-light"
                          style="width:36px;height:36px;">
                      <i class="fa fa-check-square-o text-success"/>
                    </span>
                    <span class="fw-semibold">Cân đối tồn kho</span>
                  </div>
                </div>
              </div>
            </div>

          </div>

        </t>
      </div>
    </div>
  </t>

</templates>
