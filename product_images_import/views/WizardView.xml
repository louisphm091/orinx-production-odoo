<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Wizard Form -->
    <record id="view_product_image_zip_wizard_form" model="ir.ui.view">
        <field name="name">product.image.zip.wizard.form</field>
        <field name="model">product.image.zip.wizard</field>
        <field name="arch" type="xml">
            <form string="Import Product Images from ZIP">
                <group>
                    <field name="zip_file" filename="zip_filename"/>
                    <field name="zip_filename" invisible="1"/>
                    <field name="match_by"/>
                    <field name="target"/>
                    <field name="overwrite"/>
                </group>

                <footer>
                    <button string="Import" type="object" name="action_import" class="btn-primary"/>
                    <button string="Cancel" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_product_image_zip_wizard" model="ir.actions.act_window">
        <field name="name">Import Images from ZIP</field>
        <field name="res_model">product.image.zip.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <!-- Menu under Products -->
    <menuitem id="menu_product_image_zip_import"
              name="Import Images from ZIP"
              parent="point_of_sale.pos_config_menu_catalog"
              action="action_product_image_zip_wizard"
              sequence="90"/>
</odoo>
