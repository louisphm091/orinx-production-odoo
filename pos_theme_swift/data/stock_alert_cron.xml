<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="ir_cron_swift_low_stock_alert" model="ir.cron">
            <field name="name">Swift Low Stock Alert</field>
            <field name="model_id" ref="model_swift_stock_inventory"/>
            <field name="state">code</field>
            <field name="code">model.cron_check_low_stock_alerts()</field>
            <field name="interval_number">10</field>
            <field name="interval_type">minutes</field>
            <field name="active" eval="True"/>
        </record>
    </data>
</odoo>
