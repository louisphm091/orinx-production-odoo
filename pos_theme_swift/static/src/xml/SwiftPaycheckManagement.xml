<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="pos_theme_swift.SwiftPaycheckManagement" owl="1">
        <div class="spc-page swift-inv-page">
            <div class="spc-topline">
                <div class="spc-headline" t-out="this._t('Paychecks')"/>
                <div class="spc-searchWrap">
                    <i class="fa fa-search"/>
                    <input type="text" t-att-placeholder="this._t('By code, paycheck name')" t-model="state.paycheckSearch" t-on-input="onSearchInput"/>
                </div>
                <div class="spc-tools">
                    <button class="spc-btnPrimary" t-on-click="createPaycheck"><i class="fa fa-plus me-1"/> <t t-out="this._t('Payroll Table')"/></button>
                    <button class="spc-btnLight"><i class="fa fa-share-square-o me-1"/> <t t-out="this._t('Export file')"/></button>
                    <button class="spc-iconBtn"><i class="fa fa-list"/></button>
                </div>
            </div>

            <div class="spc-content">
                <aside class="spc-filter">
                    <div class="spc-filterTitle" t-out="this._t('Branch')"/>
                    <div class="spc-chip"><t t-out="this._t('Central Branch')"/> <span>×</span></div>

                    <div class="spc-filterTitle mt" t-out="this._t('Pay Period')"/>
                    <select class="spc-select">
                        <option t-out="this._t('Select pay period')"/>
                    </select>

                    <div class="spc-filterTitle mt" t-out="this._t('Status')"/>
                    <label><input type="checkbox" checked="checked"/> <t t-out="this._t('Creating')"/></label>
                    <label><input type="checkbox" checked="checked"/> <t t-out="this._t('Provisional')"/></label>
                    <label><input type="checkbox" checked="checked"/> <t t-out="this._t('Finalized')"/></label>
                    <label><input type="checkbox"/> <t t-out="this._t('Cancelled')"/></label>
                </aside>

                <section class="spc-grid">
                    <table class="spc-table">
                        <thead>
                            <tr>
                                <th class="w-check"><input type="checkbox"/></th>
                                <th t-out="this._t('Code')"/>
                                <th t-out="this._t('Name')"/>
                                <th t-out="this._t('Cycle')"/>
                                <th t-out="this._t('Period')"/>
                                <th t-out="this._t('Branch')"/>
                                <th class="text-right" t-out="this._t('Total Salary')"/>
                                <th class="text-right" t-out="this._t('Paid to Employee')"/>
                                <th class="text-right" t-out="this._t('Remaining')"/>
                                <th t-out="this._t('Status')"/>
                            </tr>
                        </thead>
                        <tbody>
                            <tr class="spc-summary">
                                <td></td>
                                <td colspan="5"></td>
                                <td class="text-right"><t t-esc="formatMoney(getSummaryTotals().total)"/></td>
                                <td class="text-right"><t t-esc="formatMoney(getSummaryTotals().paid)"/></td>
                                <td class="text-right"><t t-esc="formatMoney(getSummaryTotals().remaining)"/></td>
                                <td></td>
                            </tr>

                            <t t-if="state.loading">
                                <tr>
                                    <td colspan="10" class="spc-empty" t-out="this._t('Loading data...')"/>
                                </tr>
                            </t>

                            <t t-foreach="state.paycheckRecords" t-as="r" t-key="r.id">
                                <tr t-att-class="state.expandedPaycheckId === r.id ? 'is-selected' : ''" t-on-click="() => togglePaycheckDetail(r.id)">
                                    <td class="w-check" t-on-click.stop=""><input type="checkbox"/></td>
                                    <td><a href="#" t-on-click.prevent=""><t t-esc="r.code"/></a></td>
                                    <td><t t-esc="r.name"/></td>
                                    <td><t t-esc="r.cycle"/></td>
                                    <td><t t-esc="r.period"/></td>
                                    <td><t t-esc="r.branch"/></td>
                                    <td class="text-right"><t t-esc="formatMoney(r.totalSalary)"/></td>
                                    <td class="text-right"><t t-esc="formatMoney(r.paidToEmployee)"/></td>
                                    <td class="text-right"><t t-esc="formatMoney(r.remaining)"/></td>
                                    <td><t t-esc="r.status"/></td>
                                </tr>

                                <t t-if="state.expandedPaycheckId === r.id">
                                    <tr>
                                        <td></td>
                                        <td colspan="9" class="spc-detailCell">
                                            <div class="spc-detailBox">
                                                <div class="spc-tabs">
                                                    <button t-att-class="'spc-tab ' + (state.paycheckTab === 'info' ? 'is-active' : '')" t-on-click="() => setPaycheckTab('info')" t-out="this._t('Info')"/>
                                                    <button t-att-class="'spc-tab ' + (state.paycheckTab === 'slip' ? 'is-active' : '')" t-on-click="() => setPaycheckTab('slip')" t-out="this._t('Payslip')"/>
                                                    <button t-att-class="'spc-tab ' + (state.paycheckTab === 'history' ? 'is-active' : '')" t-on-click="() => setPaycheckTab('history')" t-out="this._t('Payment History')"/>
                                                </div>

                                                <t t-if="state.paycheckTab === 'info'">
                                                    <div class="spc-infoGrid">
                                                        <div><span t-out="this._t('Code:')"/><strong><t t-esc="r.code"/></strong></div>
                                                        <div><span t-out="this._t('Name:')"/><strong><t t-esc="r.name"/></strong></div>
                                                        <div><span t-out="this._t('Cycle:')"/><strong><t t-esc="r.cycle"/></strong></div>
                                                        <div><span t-out="this._t('Period:')"/><strong><t t-esc="r.period"/></strong></div>
                                                        <div><span t-out="this._t('Created At:')"/><strong><t t-esc="r.createdAt || '-'"/></strong></div>
                                                        <div><span t-out="this._t('Created By:')"/><strong><t t-esc="r.createdBy || '-'"/></strong></div>
                                                        <div><span t-out="this._t('Prepared By:')"/><strong><t t-esc="r.preparedBy || '-'"/></strong></div>
                                                        <div><span t-out="this._t('Status:')"/><strong><t t-esc="r.status"/></strong></div>
                                                        <div><span t-out="this._t('Total Employees:')"/><strong><t t-esc="r.employeeCount || 0"/></strong></div>
                                                        <div><span t-out="this._t('Total Salary:')"/><strong><t t-esc="formatMoney(r.totalSalary)"/></strong></div>
                                                        <div><span t-out="this._t('Paid to Employee:')"/><strong><t t-esc="formatMoney(r.paidToEmployee)"/></strong></div>
                                                        <div><span t-out="this._t('Remaining:')"/><strong><t t-esc="formatMoney(r.remaining)"/></strong></div>
                                                        <div><span t-out="this._t('Branch:')"/><strong><t t-esc="r.branch"/></strong></div>
                                                        <div><span t-out="this._t('Scope:')"/><strong><t t-esc="r.scope || '-'"/></strong></div>
                                                        <div><span t-out="this._t('Finalized By:')"/><strong><t t-esc="r.finalizedBy || '-'"/></strong></div>
                                                        <div><span t-out="this._t('Notes:')"/><strong><t t-esc="r.note || ''"/></strong></div>
                                                    </div>
                                                    <div class="spc-detailFooter">
                                                        <button class="spc-btnGhost"><i class="fa fa-trash-o me-1"/> <t t-out="this._t('Cancel')"/></button>
                                                        <div><t t-out="this._t('Last updated at:')"/> <strong><t t-esc="r.lastUpdated || '-'"/></strong></div>
                                                        <div class="spc-footerActions">
                                                            <button class="spc-btnLight" t-on-click="loadPaychecks"><i class="fa fa-refresh me-1"/> <t t-out="this._t('Refresh Data')"/></button>
                                                            <button class="spc-btnPrimary"><i class="fa fa-check-square-o me-1"/> <t t-out="this._t('View Payroll')"/></button>
                                                            <button class="spc-btnLight"><i class="fa fa-share-square-o me-1"/> <t t-out="this._t('Export file')"/></button>
                                                        </div>
                                                    </div>
                                                </t>

                                                <t t-if="state.paycheckTab === 'slip'">
                                                    <div class="spc-slipTableWrap">
                                                        <table class="spc-slipTable">
                                                            <thead>
                                                                <tr>
                                                                    <th class="w-check"><input type="checkbox"/></th>
                                                                    <th t-out="this._t('Slip code')"/>
                                                                    <th t-out="this._t('Employee Name')"/>
                                                                    <th class="text-right" t-out="this._t('Total Salary')"/>
                                                                    <th class="text-right" t-out="this._t('Paid to Employee')"/>
                                                                    <th class="text-right" t-out="this._t('Remaining')"/>
                                                                </tr>
                                                            </thead>
                                                            <tbody>
                                                                <tr class="spc-summary">
                                                                    <td></td>
                                                                    <td colspan="2"></td>
                                                                    <td class="text-right"><t t-esc="formatMoney(r.totalSalary)"/></td>
                                                                    <td class="text-right"><t t-esc="formatMoney(r.paidToEmployee)"/></td>
                                                                    <td class="text-right"><t t-esc="formatMoney(r.remaining)"/></td>
                                                                </tr>
                                                                <t t-foreach="r.payslips || []" t-as="p" t-key="p.id || p.code">
                                                                    <tr>
                                                                        <td class="w-check"><input type="checkbox"/></td>
                                                                        <td><a href="#"><t t-esc="p.code"/></a></td>
                                                                        <td><a href="#"><t t-esc="p.employee"/></a></td>
                                                                        <td class="text-right"><t t-esc="formatMoney(p.salary)"/></td>
                                                                        <td class="text-right"><t t-esc="formatMoney(p.paid)"/></td>
                                                                        <td class="text-right"><t t-esc="formatMoney(p.remaining)"/></td>
                                                                    </tr>
                                                                </t>
                                                            </tbody>
                                                        </table>
                                                    </div>
                                                    <div class="spc-slipFooter">
                                                        <button class="spc-btnPrimary" t-on-click="openPaymentModal"><i class="fa fa-calculator me-1"/> <t t-out="this._t('Payment')"/></button>
                                                    </div>
                                                </t>

                                                <t t-if="state.paycheckTab === 'history'">
                                                    <div class="spc-slipTableWrap">
                                                        <t t-if="r.history &amp;&amp; r.history.length">
                                                            <table class="spc-slipTable">
                                                                <thead>
                                                                    <tr>
                                                                        <th t-out="this._t('Time')"/>
                                                                        <th t-out="this._t('Method')"/>
                                                                        <th class="text-right" t-out="this._t('Amount')"/>
                                                                        <th t-out="this._t('Created By')"/>
                                                                        <th t-out="this._t('Notes')"/>
                                                                    </tr>
                                                                </thead>
                                                                <tbody>
                                                                    <t t-foreach="r.history" t-as="h" t-key="h.id">
                                                                        <tr>
                                                                            <td><t t-esc="h.time"/></td>
                                                                            <td><t t-esc="h.method"/></td>
                                                                            <td class="text-right"><t t-esc="formatMoney(h.amount)"/></td>
                                                                            <td><t t-esc="h.user"/></td>
                                                                            <td><t t-esc="h.note"/></td>
                                                                        </tr>
                                                                    </t>
                                                                </tbody>
                                                            </table>
                                                        </t>
                                                        <t t-else="">
                                                            <div class="spc-empty" t-out="this._t('No payment history.')"/>
                                                        </t>
                                                    </div>
                                                </t>
                                            </div>
                                        </td>
                                    </tr>
                                </t>
                            </t>

                            <t t-if="!state.loading and !state.paycheckRecords.length">
                                <tr>
                                    <td colspan="10" class="spc-empty" t-out="this._t('No payroll data found.')"/>
                                </tr>
                            </t>
                        </tbody>
                    </table>
                </section>
            </div>

            <t t-if="state.showPaymentModal">
                <div class="spc-modalBackdrop" t-on-click="closePaymentModal"/>
                <div class="spc-modal">
                    <button class="spc-modalClose" t-on-click="closePaymentModal">×</button>
                    <h3 t-out="this._t('Payroll Payment')"/>
                    <div class="spc-modalSub">
                        <t t-if="getExpandedRecord()">
                            <t t-esc="getExpandedRecord().name"/> | <t t-out="this._t('Period:')"/> <t t-esc="getExpandedRecord().period"/> | <t t-out="this._t('Status:')"/> <t t-esc="getExpandedRecord().status"/>
                        </t>
                    </div>

                    <div class="spc-modalGrid">
                        <div><label t-out="this._t('Paid to Employee')"/><strong><t t-esc="formatMoney(getExpandedRecord() ? getExpandedRecord().remaining : 0)"/></strong></div>
                        <div><label t-out="this._t('Time')"/><input type="text" t-model="state.paymentTime"/></div>
                        <div>
                            <label t-out="this._t('Method')"/>
                            <select t-model="state.paymentMethod">
                                <option value="cash" t-out="this._t('Cash')"/>
                                <option value="bank" t-out="this._t('Bank Transfer')"/>
                            </select>
                        </div>
                        <div><label t-out="this._t('Notes')"/><input type="text" t-model="state.paymentNote"/></div>
                    </div>

                    <table class="spc-slipTable spc-modalTable" t-if="getExpandedRecord()">
                        <thead>
                            <tr>
                                <th t-out="this._t('Slip code')"/>
                                <th t-out="this._t('Employee')"/>
                                <th class="text-right" t-out="this._t('Total')"/>
                                <th class="text-right" t-out="this._t('Paid to Employee')"/>
                                <th class="text-right" t-out="this._t('Remaining')"/>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="getExpandedRecord().payslips || []" t-as="p" t-key="p.id || p.code">
                                <tr>
                                    <td><a href="#"><t t-esc="p.code"/></a></td>
                                    <td><t t-esc="p.employee"/></td>
                                    <td class="text-right"><t t-esc="formatMoney(p.salary)"/></td>
                                    <td class="text-right"><t t-esc="formatMoney(p.paid)"/></td>
                                    <td class="text-right"><t t-esc="formatMoney(p.remaining)"/></td>
                                </tr>
                            </t>
                        </tbody>
                    </table>

                    <div class="spc-modalActions">
                        <button class="spc-btnGhost" t-on-click="closePaymentModal" t-out="this._t('Cancel')"/>
                        <button class="spc-btnPrimary" t-on-click="createPaySlip" t-out="this._t('Create Payment Slip')"/>
                    </div>
                </div>
            </t>
        </div>
    </t>
</templates>
