<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="pos_theme_swift.SwiftEmployeeManagement" owl="1">
        <div class="sem-page">
            <div class="sem-topbar">
                <div class="sem-title">Danh sách nhân viên</div>
                <div class="sem-searchWrap">
                    <i class="fa fa-search"/>
                    <input type="text" placeholder="Tìm theo mã, tên nhân viên" t-model="state.keyword" t-on-input="onSearchInput"/>
                </div>
                <div class="sem-actions">
                    <button class="sem-primaryBtn" t-on-click="openCreate"><i class="fa fa-plus me-1"/> Nhân viên</button>
                    <button class="sem-lightBtn" t-att-disabled="!state.selectedUserId" t-on-click="markSelectedOff">Đánh dấu đã nghỉ</button>
                    <button class="sem-lightBtn">Duyệt yêu cầu</button>
                    <button class="sem-iconBtn"><i class="fa fa-ellipsis-h"/></button>
                </div>
            </div>

            <div class="sem-content">
                <aside class="sem-filter">
                    <div class="sem-filterTitle">Trạng thái nhân viên</div>
                    <label><input type="radio" name="empStatus" t-att-checked="state.status==='working'" t-on-click="() => setStatus('working')"/> Đang làm việc</label>
                    <label><input type="radio" name="empStatus" t-att-checked="state.status==='off'" t-on-click="() => setStatus('off')"/> Đã nghỉ</label>

                    <div class="sem-filterTitle mt">Chi nhánh làm việc</div>
                    <div class="sem-chip">Chi nhánh trung tâm <span>×</span></div>
                    <div class="sem-filterTitle mt">Chi nhánh trả lương</div>
                    <input class="sem-input" placeholder="Chọn chi nhánh"/>
                    <div class="sem-filterTitle mt">Phòng ban</div>
                    <input class="sem-input" placeholder="Chọn phòng ban"/>
                    <div class="sem-filterTitle mt">Chức danh</div>
                    <input class="sem-input" placeholder="Chọn chức danh"/>
                </aside>

                <section class="sem-main">
                    <table class="sem-table">
                        <thead>
                            <tr>
                                <th class="w-check"><input type="checkbox"/></th>
                                <th>Ảnh</th>
                                <th>Mã nhân viên</th>
                                <th>Mã chấm công</th>
                                <th>Tên nhân viên</th>
                                <th>Số điện thoại</th>
                                <th>Số CMND/CCCD</th>
                                <th>Nợ và tạm ứng</th>
                                <th>Ghi chú</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-if="state.loading">
                                <tr><td colspan="9" class="sem-empty">Đang tải dữ liệu...</td></tr>
                            </t>

                            <t t-foreach="state.rows" t-as="r" t-key="r.userId">
                                <tr t-att-class="state.selectedUserId===r.userId ? 'is-selected' : ''" t-on-click="() => selectRow(r)">
                                    <td class="w-check"><input type="checkbox"/></td>
                                    <td><div class="sem-avatar"/></td>
                                    <td><t t-esc="r.employeeCode"/></td>
                                    <td><t t-esc="r.attendanceCode"/></td>
                                    <td><t t-esc="r.employeeName"/></td>
                                    <td><t t-esc="r.phone"/></td>
                                    <td><t t-esc="r.idNumber"/></td>
                                    <td class="text-right"><t t-esc="formatMoney(r.debtAdvance)"/></td>
                                    <td><t t-esc="r.note"/></td>
                                </tr>

                                <t t-if="state.selectedUserId===r.userId and state.detail">
                                    <tr>
                                        <td></td>
                                        <td colspan="8" class="sem-detailCell">
                                            <div class="sem-detailBox">
                                                <div class="sem-tabs">
                                                    <button t-att-class="'sem-tab ' + (state.activeTab==='info'?'is-active':'')" t-on-click="() => setTab('info')">Thông tin</button>
                                                    <button t-att-class="'sem-tab ' + (state.activeTab==='schedule'?'is-active':'')" t-on-click="() => setTab('schedule')">Lịch làm việc</button>
                                                    <button t-att-class="'sem-tab ' + (state.activeTab==='salary'?'is-active':'')" t-on-click="() => setTab('salary')">Thiết lập lương</button>
                                                    <button t-att-class="'sem-tab ' + (state.activeTab==='payslip'?'is-active':'')" t-on-click="() => setTab('payslip')">Phiếu lương</button>
                                                    <button t-att-class="'sem-tab ' + (state.activeTab==='finance'?'is-active':'')" t-on-click="() => setTab('finance')">Nợ và tạm ứng</button>
                                                </div>

                                                <t t-if="state.activeTab==='info'">
                                                    <div class="sem-gridInfo">
                                                        <div><span>Mã nhân viên</span><strong><t t-esc="state.detail.profile.employeeCode"/></strong></div>
                                                        <div><span>Mã chấm công</span><strong><t t-esc="state.detail.profile.attendanceCode"/></strong></div>
                                                        <div><span>Tên</span><strong><t t-esc="state.detail.profile.name"/></strong></div>
                                                        <div><span>Số điện thoại</span><strong><t t-esc="state.detail.profile.phone"/></strong></div>
                                                        <div><span>Số CMND/CCCD</span><strong><t t-esc="state.detail.profile.idNumber"/></strong></div>
                                                        <div><span>Ngày sinh</span><strong><t t-esc="state.detail.profile.birthDate || '-'"/></strong></div>
                                                        <div><span>Giới tính</span><strong><t t-esc="state.detail.profile.gender || '-'"/></strong></div>
                                                        <div><span>Chi nhánh làm việc</span><strong><t t-esc="state.detail.profile.workBranch"/></strong></div>
                                                        <div><span>Chi nhánh trả lương</span><strong><t t-esc="state.detail.profile.payBranch"/></strong></div>
                                                        <div><span>Phòng ban</span><strong><t t-esc="state.detail.profile.department || '-'"/></strong></div>
                                                        <div><span>Chức danh</span><strong><t t-esc="state.detail.profile.jobTitle || '-'"/></strong></div>
                                                    </div>
                                                </t>

                                                <t t-if="state.activeTab==='schedule'">
                                                    <table class="sem-miniTable">
                                                        <thead>
                                                            <tr>
                                                                <th>Ca</th>
                                                                <t t-foreach="state.detail.days" t-as="d" t-key="d.date"><th><t t-esc="d.label"/> <t t-esc="d.day"/></th></t>
                                                            </tr>
                                                        </thead>
                                                        <tbody>
                                                            <t t-foreach="state.detail.scheduleShifts" t-as="s" t-key="s.id">
                                                                <tr>
                                                                    <td><strong><t t-esc="s.name"/></strong><br/><span class="sub"><t t-esc="s.time"/></span></td>
                                                                    <t t-foreach="state.detail.days" t-as="d" t-key="s.id + d.date">
                                                                        <td class="text-center">
                                                                            <t t-if="s.days.includes(d.date)"><i class="fa fa-check text-primary"/></t>
                                                                        </td>
                                                                    </t>
                                                                </tr>
                                                            </t>
                                                            <t t-if="!state.detail.scheduleShifts.length">
                                                                <tr><td t-att-colspan="state.detail.days.length + 1" class="sem-empty">Chưa có lịch làm việc tuần này.</td></tr>
                                                            </t>
                                                        </tbody>
                                                    </table>
                                                </t>

                                                <t t-if="state.activeTab==='salary'">
                                                    <div class="sem-salaryCard">
                                                        <div class="sem-row">
                                                            <label>Loại lương</label>
                                                            <select t-model="state.detail.profile.salaryType">
                                                                <option value="hour">Theo giờ làm việc</option>
                                                                <option value="shift">Theo ca làm việc</option>
                                                                <option value="month">Theo tháng</option>
                                                            </select>
                                                        </div>
                                                        <div class="sem-row">
                                                            <label>Mức lương</label>
                                                            <input type="text" t-att-value="formatMoney(state.detail.profile.salaryAmount)" t-on-input="onDetailSalaryInput"/>
                                                            <span class="sem-unit">
                                                                <t t-if="state.detail.profile.salaryType==='hour'">/ giờ</t>
                                                                <t t-if="state.detail.profile.salaryType==='shift'">/ ca</t>
                                                                <t t-if="state.detail.profile.salaryType==='month'">/ tháng</t>
                                                            </span>
                                                        </div>
                                                        <div class="sem-row end">
                                                            <label>Thiết lập nâng cao</label>
                                                            <input type="checkbox" t-model="state.detail.profile.advancedSetting"/>
                                                        </div>
                                                        <div class="sem-row end">
                                                            <label>Lương làm thêm giờ</label>
                                                            <input type="checkbox" t-model="state.detail.profile.overtimeEnabled"/>
                                                        </div>
                                                    </div>
                                                    <div class="sem-actionsRow">
                                                        <button class="sem-primaryBtn" t-on-click="saveSalary">Cập nhật</button>
                                                    </div>
                                                </t>

                                                <t t-if="state.activeTab==='payslip'">
                                                    <table class="sem-miniTable">
                                                        <thead>
                                                            <tr>
                                                                <th>Mã phiếu</th>
                                                                <th>Kỳ làm việc</th>
                                                                <th class="text-right">Tổng lương</th>
                                                                <th class="text-right">Đã trả</th>
                                                                <th class="text-right">Còn cần trả</th>
                                                                <th>Trạng thái</th>
                                                            </tr>
                                                        </thead>
                                                        <tbody>
                                                            <t t-foreach="state.detail.payslips" t-as="p" t-key="p.code + p.period">
                                                                <tr>
                                                                    <td><a href="#"><t t-esc="p.code"/></a></td>
                                                                    <td><t t-esc="p.period"/></td>
                                                                    <td class="text-right"><t t-esc="formatMoney(p.total)"/></td>
                                                                    <td class="text-right"><t t-esc="formatMoney(p.paid)"/></td>
                                                                    <td class="text-right"><t t-esc="formatMoney(p.remaining)"/></td>
                                                                    <td><t t-esc="p.status"/></td>
                                                                </tr>
                                                            </t>
                                                            <t t-if="!state.detail.payslips.length">
                                                                <tr><td colspan="6" class="sem-empty">Chưa có phiếu lương.</td></tr>
                                                            </t>
                                                        </tbody>
                                                    </table>
                                                </t>

                                                <t t-if="state.activeTab==='finance'">
                                                    <div class="sem-finTop">
                                                        <div><strong>Số dư nợ và tạm ứng: </strong><t t-esc="formatMoney(state.detail.profile.debtAdvance)"/></div>
                                                        <div class="sem-finBtns">
                                                            <button class="sem-lightBtn" t-on-click="() => openFinance('debt')">Thêm nợ</button>
                                                            <button class="sem-lightBtn" t-on-click="() => openFinance('advance')">Thêm tạm ứng</button>
                                                            <button class="sem-primaryBtn" t-on-click="() => openFinance('payment')">Ghi nhận thanh toán</button>
                                                        </div>
                                                    </div>
                                                    <table class="sem-miniTable">
                                                        <thead>
                                                            <tr><th>Ngày</th><th>Loại</th><th class="text-right">Số tiền</th><th>Ghi chú</th></tr>
                                                        </thead>
                                                        <tbody>
                                                            <t t-foreach="state.detail.financeRows" t-as="f" t-key="f.date + f.type + f.amount + f.note">
                                                                <tr>
                                                                    <td><t t-esc="f.date"/></td>
                                                                    <td><t t-esc="f.type"/></td>
                                                                    <td class="text-right"><t t-esc="formatMoney(f.amount)"/></td>
                                                                    <td><t t-esc="f.note"/></td>
                                                                </tr>
                                                            </t>
                                                            <t t-if="!state.detail.financeRows.length">
                                                                <tr><td colspan="4" class="sem-empty">Chưa có dữ liệu nợ và tạm ứng.</td></tr>
                                                            </t>
                                                        </tbody>
                                                    </table>
                                                </t>
                                            </div>
                                        </td>
                                    </tr>
                                </t>
                            </t>

                            <t t-if="!state.loading and !state.rows.length">
                                <tr><td colspan="9" class="sem-empty">Không có dữ liệu nhân viên.</td></tr>
                            </t>
                        </tbody>
                    </table>
                </section>
            </div>

            <t t-if="state.showCreateModal">
                <div class="sem-modalBackdrop" t-on-click="closeCreate"/>
                <div class="sem-modal">
                    <button class="sem-modalClose" t-on-click="closeCreate">×</button>
                    <h3>Thêm mới nhân viên</h3>
                    <div class="sem-formGrid">
                        <label>Chọn từ người dùng có sẵn</label>
                        <select t-att-value="state.createForm.userId" t-on-change="onSelectAvailableUser">
                            <option value="">-- Tạo nhân viên mới --</option>
                            <t t-foreach="state.availableUsers" t-as="u" t-key="u.userId">
                                <option t-att-value="u.userId"><t t-esc="u.name"/> (<t t-esc="u.login"/>)</option>
                            </t>
                        </select>
                        <label>Tên nhân viên</label><input type="text" t-model="state.createForm.name"/>
                        <label>Số điện thoại</label><input type="text" t-model="state.createForm.phone"/>
                        <label>Số CMND/CCCD</label><input type="text" t-model="state.createForm.idNumber"/>
                        <label>Ngày sinh</label><input type="date" t-model="state.createForm.birthDate"/>
                        <label>Giới tính</label>
                        <select t-model="state.createForm.gender"><option value="">--</option><option value="male">Nam</option><option value="female">Nữ</option></select>
                        <label>Chi nhánh làm việc</label><input type="text" t-model="state.createForm.workBranch"/>
                        <label>Chi nhánh trả lương</label><input type="text" t-model="state.createForm.payBranch"/>
                        <label>Loại lương</label>
                        <select t-model="state.createForm.salaryType"><option value="hour">Theo giờ làm việc</option><option value="shift">Theo ca làm việc</option><option value="month">Theo tháng</option></select>
                        <label>Mức lương</label><input type="text" t-att-value="formatMoney(state.createForm.salaryAmount)" t-on-input="onCreateSalaryInput"/>
                    </div>
                    <div class="sem-actionsRow">
                        <button class="sem-lightBtn" t-on-click="closeCreate">Bỏ qua</button>
                        <button class="sem-primaryBtn" t-on-click="saveCreate">Lưu</button>
                    </div>
                </div>
            </t>

            <t t-if="state.showFinanceModal">
                <div class="sem-modalBackdrop" t-on-click="closeFinance"/>
                <div class="sem-modal sem-small">
                    <button class="sem-modalClose" t-on-click="closeFinance">×</button>
                    <h3>Thêm nợ và tạm ứng</h3>
                    <div class="sem-formGrid">
                        <label>Loại</label>
                        <select t-model="state.financeForm.type"><option value="debt">Nợ</option><option value="advance">Tạm ứng</option><option value="payment">Thanh toán</option></select>
                        <label>Số tiền</label><input type="number" t-model="state.financeForm.amount"/>
                        <label>Ghi chú</label><input type="text" t-model="state.financeForm.note"/>
                    </div>
                    <div class="sem-actionsRow">
                        <button class="sem-lightBtn" t-on-click="closeFinance">Bỏ qua</button>
                        <button class="sem-primaryBtn" t-on-click="saveFinance">Lưu</button>
                    </div>
                </div>
            </t>
        </div>
    </t>
</templates>
