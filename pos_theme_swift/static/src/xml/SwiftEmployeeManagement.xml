<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="pos_theme_swift.SwiftEmployeeManagement" owl="1">
        <div class="sem-page">
            <section class="sem-hero">
                <div class="sem-heroCopy">
                    <div class="sem-kicker" t-out="this._t('Employee Management')"/>
                    <div class="sem-title" t-out="this._t('Manage Staff and Shift Attendance')"/>
                    <div class="sem-subtitle" t-out="this._t('A polished workspace to manage employee profiles and monitor daily check-in / check-out in one place.')"/>
                </div>
                <div class="sem-heroStats">
                    <div class="sem-statCard">
                        <span class="sem-statLabel" t-out="this._t('Working Staff')"/>
                        <strong t-esc="getWorkingCount()"/>
                    </div>
                    <div class="sem-statCard">
                        <span class="sem-statLabel" t-out="this._t('Off Staff')"/>
                        <strong t-esc="getOffCount()"/>
                    </div>
                    <div class="sem-statCard">
                        <span class="sem-statLabel" t-out="this._t('Active Shifts')"/>
                        <strong t-esc="getActiveShiftCount()"/>
                    </div>
                    <div class="sem-statCard">
                        <span class="sem-statLabel" t-out="this._t('Checked Out')"/>
                        <strong t-esc="getAttendanceReadyCount()"/>
                    </div>
                </div>
            </section>

            <section class="sem-card sem-checkinBoard">
                <div class="sem-boardHead">
                    <div>
                        <div class="sem-sectionTitle" t-out="this._t('Staff Check-in / Check-out Tracker')"/>
                        <div class="sem-sectionSub" t-out="this._t('Track attendance by day and operate check-in or check-out directly from the board.')"/>
                    </div>
                    <div class="sem-boardActions">
                        <label class="sem-dateField">
                            <i class="fa fa-calendar-o"/>
                            <input type="date" t-att-value="state.attendanceDate" t-on-change="onAttendanceDateChange"/>
                        </label>
                    </div>
                </div>

                <div class="sem-attendanceTableWrap">
                    <table class="sem-attendanceTable">
                        <thead>
                            <tr>
                                <th><t t-out="this._t('Employee Code')"/></th>
                                <th><t t-out="this._t('Employee Name')"/></th>
                                <th><t t-out="this._t('Phone Number')"/></th>
                                <th><t t-out="this._t('Check In')"/></th>
                                <th><t t-out="this._t('Check Out')"/></th>
                                <th><t t-out="this._t('Working Time')"/></th>
                                <th><t t-out="this._t('Status')"/></th>
                                <th><t t-out="this._t('Note')"/></th>
                                <th class="text-right"><t t-out="this._t('Action')"/></th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-if="state.attendanceLoading">
                                <tr><td colspan="9" class="sem-empty" t-out="this._t('Loading check-in / check-out board...')"/></tr>
                            </t>
                            <t t-foreach="state.attendanceRows" t-as="row" t-key="'att-' + row.userId">
                                <tr>
                                    <td><strong><t t-esc="row.employeeCode"/></strong></td>
                                    <td>
                                        <div class="sem-personCell">
                                            <t t-if="row.avatarUrl">
                                                <img class="sem-avatar sem-avatarBig sem-avatarImg" t-att-src="row.avatarUrl" t-att-alt="row.employeeName"/>
                                            </t>
                                            <t t-else="">
                                                <div class="sem-avatar sem-avatarBig"><t t-esc="getInitials(row.employeeName)"/></div>
                                            </t>
                                            <div>
                                                <div class="sem-personName"><t t-esc="row.employeeName"/></div>
                                            </div>
                                        </div>
                                    </td>
                                    <td><t t-esc="row.phone || '--'"/></td>
                                    <td><span class="sem-timeBadge"><t t-esc="row.checkIn"/></span></td>
                                    <td><span class="sem-timeBadge is-out"><t t-esc="row.checkOut"/></span></td>
                                    <td><t t-esc="row.hours"/>h</td>
                                    <td><span class="sem-statusPill" t-att-class="getAttendanceToneClass(row.statusTone)"><t t-esc="row.statusLabel"/></span></td>
                                    <td><t t-esc="row.note || '--'"/></td>
                                    <td class="text-right">
                                        <div class="sem-inlineActions">
                                            <button class="sem-primaryBtn sem-miniBtn" t-if="row.canCheckIn" t-on-click="() => openAttendanceModal('action_employee_checkin', row)" t-out="this._t('Check In')"/>
                                            <button class="sem-lightBtn sem-miniBtn" t-if="row.canCheckOut" t-on-click="() => openAttendanceModal('action_employee_checkout', row)" t-out="this._t('Check Out')"/>
                                            <span t-if="!row.canCheckIn and !row.canCheckOut" class="sem-quietText" t-out="this._t('No action')"/>
                                        </div>
                                    </td>
                                </tr>
                            </t>
                            <t t-if="!state.attendanceLoading and !state.attendanceRows.length">
                                <tr><td colspan="9" class="sem-empty" t-out="this._t('No attendance records for this day.')"/></tr>
                            </t>
                        </tbody>
                    </table>
                </div>
            </section>

            <div class="sem-topbar">
                <div class="sem-titleSm" t-out="this._t('Employee Directory')"/>
                <div class="sem-searchWrap">
                    <i class="fa fa-search"/>
                    <input type="text" t-att-placeholder="this._t('Search by code, employee name')" t-model="state.keyword" t-on-input="onSearchInput"/>
                </div>
                    <div class="sem-actions">
                        <button class="sem-primaryBtn" t-on-click="openCreate"><i class="fa fa-plus me-1"/> <t t-out="this._t('Employee')"/></button>
                        <button class="sem-lightBtn" t-att-disabled="!state.selectedUserId" t-on-click="openEditEmployee" t-out="this._t('Edit Employee')"/>
                        <t t-if="state.status === 'working'">
                            <button class="sem-lightBtn" t-att-disabled="!state.selectedUserId" t-on-click="markSelectedOff" t-out="this._t('Mark as Off')"/>
                        </t>
                    <t t-else="">
                        <button class="sem-lightBtn" t-att-disabled="!state.selectedUserId" t-on-click="markSelectedWorking" t-out="this._t('Mark as Working')"/>
                    </t>
                    <button class="sem-lightBtn" t-att-disabled="!state.selectedUserId" t-on-click="deleteSelectedEmployee" t-out="this._t('Delete Employee')"/>
                </div>
            </div>

            <div class="sem-content">
                <aside class="sem-card sem-filter">
                    <div class="sem-filterTitle" t-out="this._t('Employee Status')"/>
                    <label><input type="radio" name="empStatus" t-att-checked="state.status==='working'" t-on-click="() => setStatus('working')"/> <t t-out="this._t('Working')"/></label>
                    <label><input type="radio" name="empStatus" t-att-checked="state.status==='off'" t-on-click="() => setStatus('off')"/> <t t-out="this._t('Off')"/></label>

                    <div class="sem-filterTitle mt" t-out="this._t('Work Branch')"/>
                    <select class="sem-input" t-att-value="state.filters.workBranch" t-on-change="(ev) => onFilterChange('workBranch', ev.target.value)">
                        <option value="" t-out="this._t('All branches')"/>
                        <t t-foreach="state.filterOptions.workBranches" t-as="branch" t-key="'filter-work-' + branch.id">
                            <option t-att-value="branch.name"><t t-esc="branch.name"/></option>
                        </t>
                    </select>
                    <div class="sem-filterTitle mt" t-out="this._t('Pay Branch')"/>
                    <select class="sem-input" t-att-value="state.filters.payBranch" t-on-change="(ev) => onFilterChange('payBranch', ev.target.value)">
                        <option value="" t-out="this._t('All branches')"/>
                        <t t-foreach="state.filterOptions.payBranches" t-as="branch" t-key="'filter-pay-' + branch.id">
                            <option t-att-value="branch.name"><t t-esc="branch.name"/></option>
                        </t>
                    </select>
                    <div class="sem-filterTitle mt" t-out="this._t('Department')"/>
                    <select class="sem-input" t-att-value="state.filters.department" t-on-change="(ev) => onFilterChange('department', ev.target.value)">
                        <option value="" t-out="this._t('All departments')"/>
                        <t t-foreach="state.filterOptions.departments" t-as="department" t-key="'filter-department-' + department.id">
                            <option t-att-value="department.name"><t t-esc="department.name"/></option>
                        </t>
                    </select>
                    <div class="sem-filterTitle mt" t-out="this._t('Job Title')"/>
                    <select class="sem-input" t-att-value="state.filters.jobTitle" t-on-change="(ev) => onFilterChange('jobTitle', ev.target.value)">
                        <option value="" t-out="this._t('All job titles')"/>
                        <t t-foreach="state.filterOptions.jobTitles" t-as="jobTitle" t-key="'filter-job-' + jobTitle.id">
                            <option t-att-value="jobTitle.name"><t t-esc="jobTitle.name"/></option>
                        </t>
                    </select>
                </aside>

                <section class="sem-card sem-main">
                    <table class="sem-table">
                        <thead>
                            <tr>
                                <th class="w-check"><input type="checkbox"/></th>
                                <th><t t-out="this._t('Image')"/></th>
                                <th><t t-out="this._t('Employee Code')"/></th>
                                <th><t t-out="this._t('Attendance Code')"/></th>
                                <th><t t-out="this._t('Employee Name')"/></th>
                                <th><t t-out="this._t('Phone Number')"/></th>
                                <th><t t-out="this._t('ID Number')"/></th>
                                <th><t t-out="this._t('Debt/Advance')"/></th>
                                <th><t t-out="this._t('Notes')"/></th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-if="state.loading">
                                <tr><td colspan="9" class="sem-empty" t-out="this._t('Loading data...')"/></tr>
                            </t>

                            <t t-foreach="state.rows" t-as="r" t-key="r.userId">
                                <tr t-att-class="state.selectedUserId===r.userId ? 'is-selected' : ''" t-on-click="() => selectRow(r)">
                                    <td class="w-check"><input type="checkbox"/></td>
                                    <td>
                                        <t t-if="r.avatarUrl">
                                            <img class="sem-avatar sem-avatarImg" t-att-src="r.avatarUrl" t-att-alt="r.employeeName"/>
                                        </t>
                                        <t t-else="">
                                            <div class="sem-avatar"><t t-esc="getInitials(r.employeeName)"/></div>
                                        </t>
                                    </td>
                                    <td><t t-esc="r.employeeCode"/></td>
                                    <td><t t-esc="r.attendanceCode"/></td>
                                    <td><t t-esc="r.employeeName"/></td>
                                    <td><t t-esc="r.phone"/></td>
                                    <td><t t-esc="r.idNumber"/></td>
                                    <td class="text-right"><t t-esc="formatMoney(r.debtAdvance)"/></td>
                                    <td><t t-esc="r.note"/></td>
                                </tr>

                                <t t-if="state.selectedUserId===r.userId and state.detail">
                                    <tr>
                                        <td></td>
                                        <td colspan="8" class="sem-detailCell">
                                            <div class="sem-detailBox">
                                                <div class="sem-tabs">
                                                    <button t-att-class="'sem-tab ' + (state.activeTab==='info'?'is-active':'')" t-on-click="() => setTab('info')" t-out="this._t('Info')"/>
                                                    <button t-att-class="'sem-tab ' + (state.activeTab==='schedule'?'is-active':'')" t-on-click="() => setTab('schedule')" t-out="this._t('Schedule')"/>
                                                    <button t-att-class="'sem-tab ' + (state.activeTab==='salary'?'is-active':'')" t-on-click="() => setTab('salary')" t-out="this._t('Salary Setup')"/>
                                                    <button t-att-class="'sem-tab ' + (state.activeTab==='payslip'?'is-active':'')" t-on-click="() => setTab('payslip')" t-out="this._t('Payslip')"/>
                                                    <button t-att-class="'sem-tab ' + (state.activeTab==='finance'?'is-active':'')" t-on-click="() => setTab('finance')" t-out="this._t('Debt/Advance')"/>
                                                </div>

                                                <t t-if="state.activeTab==='info'">
                                                    <div class="sem-gridInfo">
                                                        <div><span t-out="this._t('Employee Code')"/><strong><t t-esc="state.detail.profile.employeeCode"/></strong></div>
                                                        <div><span t-out="this._t('Attendance Code')"/><strong><t t-esc="state.detail.profile.attendanceCode"/></strong></div>
                                                        <div><span t-out="this._t('Name')"/><strong><t t-esc="state.detail.profile.name"/></strong></div>
                                                        <div><span t-out="this._t('Phone Number')"/><strong><t t-esc="state.detail.profile.phone"/></strong></div>
                                                        <div><span t-out="this._t('ID Number')"/><strong><t t-esc="state.detail.profile.idNumber"/></strong></div>
                                                        <div><span t-out="this._t('Birth Date')"/><strong><t t-esc="state.detail.profile.birthDate || '-'"/></strong></div>
                                                        <div><span t-out="this._t('Gender')"/><strong><t t-esc="state.detail.profile.gender || '-'"/></strong></div>
                                                        <div><span t-out="this._t('Work Branch')"/><strong><t t-esc="state.detail.profile.workBranch"/></strong></div>
                                                        <div><span t-out="this._t('Pay Branch')"/><strong><t t-esc="state.detail.profile.payBranch"/></strong></div>
                                                        <div><span t-out="this._t('Department')"/><strong><t t-esc="state.detail.profile.department || '-'"/></strong></div>
                                                        <div><span t-out="this._t('Job Title')"/><strong><t t-esc="state.detail.profile.jobTitle || '-'"/></strong></div>
                                                        <div class="sem-pinRow" style="grid-column: 1 / -1; display: flex; align-items: center; gap: 10px; margin-top: 10px; padding-top: 10px; border-top: 1px solid #eee;">
                                                            <span t-out="this._t('POS PIN')" style="font-weight: 600; font-size: 0.85rem; color: #64748b;"/>
                                                            <input type="password" class="sem-input" t-model="state.pinDraft" autocomplete="new-password" placeholder="••••••" style="width: 150px; display: inline-block; padding: 6px 10px; border: 1px solid #e2e8f0; border-radius: 6px; outline: none; transition: border-color 0.2s;" onfocus="this.style.borderColor='#3b82f6'" onblur="this.style.borderColor='#e2e8f0'"/>
                                                            <button class="sem-primaryBtn sem-miniBtn" t-on-click="savePin" t-out="this._t('Update PIN')"/>
                                                        </div>
                                                    </div>
                                                    <div class="sem-actionsRow">
                                                        <button class="sem-lightBtn" t-on-click="openEditEmployee" t-out="this._t('Edit Employee')"/>
                                                        <t t-if="state.status === 'working'">
                                                            <button class="sem-lightBtn" t-on-click="markSelectedOff" t-out="this._t('Mark as Off')"/>
                                                        </t>
                                                        <t t-else="">
                                                            <button class="sem-lightBtn" t-on-click="markSelectedWorking" t-out="this._t('Mark as Working')"/>
                                                        </t>
                                                        <button class="sem-lightBtn" t-on-click="deleteSelectedEmployee" t-out="this._t('Delete Employee')"/>
                                                    </div>
                                                </t>

                                                <t t-if="state.activeTab==='schedule'">
                                                    <table class="sem-miniTable">
                                                        <thead>
                                                            <tr>
                                                                <th t-out="this._t('Shift')"/>
                                                                <t t-foreach="state.detail.days" t-as="d" t-key="d.date"><th><t t-esc="d.label"/> <t t-esc="d.day"/></th></t>
                                                            </tr>
                                                        </thead>
                                                        <tbody>
                                                            <t t-foreach="state.detail.scheduleShifts" t-as="s" t-key="s.id">
                                                                <tr>
                                                                    <td><strong><t t-esc="s.name"/></strong><br/><span class="sub"><t t-esc="s.time"/></span></td>
                                                                    <t t-foreach="state.detail.days" t-as="d" t-key="s.id + d.date">
                                                                        <td class="text-center">
                                                                            <t t-if="s.days.includes(d.date)"><i class="fa fa-check text-primary"/></t>
                                                                        </td>
                                                                    </t>
                                                                </tr>
                                                            </t>
                                                            <t t-if="!state.detail.scheduleShifts.length">
                                                                <tr><td t-att-colspan="state.detail.days.length + 1" class="sem-empty" t-out="this._t('No work schedule for this week.')"/></tr>
                                                            </t>
                                                        </tbody>
                                                    </table>
                                                </t>

                                                <t t-if="state.activeTab==='salary'">
                                                    <div class="sem-salaryCard">
                                                        <div class="sem-row">
                                                            <label t-out="this._t('Salary Type')"/>
                                                            <select t-model="state.detail.profile.salaryType">
                                                                <option value="hour" t-out="this._t('By working hour')"/>
                                                                <option value="shift" t-out="this._t('By working shift')"/>
                                                                <option value="month" t-out="this._t('By month')"/>
                                                            </select>
                                                        </div>
                                                        <div class="sem-row">
                                                            <label t-out="this._t('Salary Amount')"/>
                                                            <input type="text" t-att-value="formatMoney(state.detail.profile.salaryAmount)" t-on-input="onDetailSalaryInput"/>
                                                            <span class="sem-unit">
                                                                <t t-if="state.detail.profile.salaryType==='hour'">/ <t t-out="this._t('hour')"/></t>
                                                                <t t-if="state.detail.profile.salaryType==='shift'">/ <t t-out="this._t('shift')"/></t>
                                                                <t t-if="state.detail.profile.salaryType==='month'">/ <t t-out="this._t('month')"/></t>
                                                            </span>
                                                        </div>
                                                        <div class="sem-row end">
                                                            <label t-out="this._t('Advanced Setting')"/>
                                                            <input type="checkbox" t-model="state.detail.profile.advancedSetting"/>
                                                        </div>
                                                        <div class="sem-row end">
                                                            <label t-out="this._t('Overtime Salary')"/>
                                                            <input type="checkbox" t-model="state.detail.profile.overtimeEnabled"/>
                                                        </div>
                                                    </div>
                                                    <div class="sem-actionsRow">
                                                        <button class="sem-primaryBtn" t-on-click="saveSalary" t-out="this._t('Update')"/>
                                                    </div>
                                                </t>

                                                <t t-if="state.activeTab==='payslip'">
                                                    <table class="sem-miniTable">
                                                        <thead>
                                                            <tr>
                                                                <th t-out="this._t('Slip code')"/>
                                                                <th t-out="this._t('Period')"/>
                                                                <th class="text-right" t-out="this._t('Total salary')"/>
                                                                <th class="text-right" t-out="this._t('Paid')"/>
                                                                <th class="text-right" t-out="this._t('Remaining')"/>
                                                                <th t-out="this._t('Status')"/>
                                                            </tr>
                                                        </thead>
                                                        <tbody>
                                                            <t t-foreach="state.detail.payslips" t-as="p" t-key="p.code + p.period">
                                                                <tr>
                                                                    <td><a href="#"><t t-esc="p.code"/></a></td>
                                                                    <td><t t-esc="p.period"/></td>
                                                                    <td class="text-right"><t t-esc="formatMoney(p.total)"/></td>
                                                                    <td class="text-right"><t t-esc="formatMoney(p.paid)"/></td>
                                                                    <td class="text-right"><t t-esc="formatMoney(p.remaining)"/></td>
                                                                    <td><t t-esc="p.status"/></td>
                                                                </tr>
                                                            </t>
                                                            <t t-if="!state.detail.payslips.length">
                                                                <tr><td colspan="6" class="sem-empty" t-out="this._t('No payslips available.')"/></tr>
                                                            </t>
                                                        </tbody>
                                                    </table>
                                                </t>

                                                <t t-if="state.activeTab==='finance'">
                                                    <div class="sem-finTop">
                                                        <div><strong t-out="this._t('Debt/Advance Balance:')"/> <t t-esc="formatMoney(state.detail.profile.debtAdvance)"/></div>
                                                        <div class="sem-finBtns">
                                                            <button class="sem-lightBtn" t-on-click="() => openFinance('debt')" t-out="this._t('Add Debt')"/>
                                                            <button class="sem-lightBtn" t-on-click="() => openFinance('advance')" t-out="this._t('Add Advance')"/>
                                                            <button class="sem-primaryBtn" t-on-click="() => openFinance('payment')" t-out="this._t('Record Payment')"/>
                                                        </div>
                                                    </div>
                                                    <table class="sem-miniTable">
                                                        <thead>
                                                            <tr><th t-out="this._t('Date')"/><th t-out="this._t('Type')"/><th class="text-right" t-out="this._t('Amount')"/><th t-out="this._t('Notes')"/></tr>
                                                        </thead>
                                                        <tbody>
                                                            <t t-foreach="state.detail.financeRows" t-as="f" t-key="f.date + f.type + f.amount + f.note">
                                                                <tr>
                                                                    <td><t t-esc="f.date"/></td>
                                                                    <td><t t-esc="f.type"/></td>
                                                                    <td class="text-right"><t t-esc="formatMoney(f.amount)"/></td>
                                                                    <td><t t-esc="f.note"/></td>
                                                                </tr>
                                                            </t>
                                                            <t t-if="!state.detail.financeRows.length">
                                                                <tr><td colspan="4" class="sem-empty" t-out="this._t('No debt/advance data available.')"/></tr>
                                                            </t>
                                                        </tbody>
                                                    </table>
                                                </t>
                                            </div>
                                        </td>
                                    </tr>
                                </t>
                            </t>

                            <t t-if="!state.loading and !state.rows.length">
                                <tr><td colspan="9" class="sem-empty" t-out="this._t('No employee data found.')"/></tr>
                            </t>
                        </tbody>
                    </table>
                </section>
            </div>

            <t t-if="state.showCreateModal">
                <div class="sem-modalBackdrop" t-on-click="closeCreate"/>
                <div class="sem-modal">
                    <button class="sem-modalClose" t-on-click="closeCreate">×</button>
                    <h3 t-out="state.formMode === 'edit' ? this._t('Edit Employee') : this._t('Add New Employee')"/>
                    <div class="sem-formGrid">
                        <t t-if="state.formMode === 'create'">
                            <label t-out="this._t('Select from existing users')"/>
                            <select t-att-value="state.createForm.userId" t-on-change="onSelectAvailableUser">
                                <option value="" t-out="this._t('-- Create New Employee --')"/>
                                <t t-foreach="state.availableUsers" t-as="u" t-key="u.userId">
                                    <option t-att-value="u.userId"><t t-esc="u.name"/> (<t t-esc="u.login"/>)</option>
                                </t>
                            </select>
                        </t>
                        <t t-else="">
                            <label t-out="this._t('Employee')"/>
                            <input type="text" t-att-value="state.createForm.name" readonly="readonly"/>
                        </t>
                        <label t-out="this._t('Employee Name')"/><input type="text" t-model="state.createForm.name"/>
                        <label t-out="this._t('Phone Number')"/><input type="text" t-model="state.createForm.phone"/>
                        <label t-out="this._t('ID Number')"/><input type="text" t-model="state.createForm.idNumber"/>
                        <label t-out="this._t('POS PIN')"/><input type="password" autocomplete="new-password" t-model="state.createForm.posPin"/>
                        <label t-out="this._t('Birth Date')"/><input type="date" t-model="state.createForm.birthDate"/>
                        <label t-out="this._t('Gender')"/>
                        <select t-model="state.createForm.gender"><option value="">--</option><option value="male" t-out="this._t('Male')"/><option value="female" t-out="this._t('Female')"/></select>
                        <label t-out="this._t('Department')"/>
                        <input type="text" t-model="state.createForm.department"/>
                        <label t-out="this._t('Position')"/>
                        <select t-model="state.createForm.jobTitle">
                            <option value="" t-out="this._t('Select position')"/>
                            <t t-if="state.filterOptions.jobTitles.length">
                                <t t-foreach="state.filterOptions.jobTitles" t-as="jobTitle" t-key="'create-job-' + jobTitle.id">
                                    <option t-att-value="jobTitle.id"><t t-esc="jobTitle.name"/></option>
                                </t>
                            </t>
                            <t t-else="">
                                <option value="" t-out="this._t('No position available.')"/>
                            </t>
                        </select>
                        <label t-out="this._t('Work Branch')"/>
                        <select t-model="state.createForm.workBranch">
                            <option value="" t-out="this._t('Select branch')"/>
                            <t t-foreach="state.branches" t-as="branch" t-key="'work-' + branch.id">
                                <option t-att-value="branch.name"><t t-esc="branch.name"/></option>
                            </t>
                        </select>
                        <label t-out="this._t('Pay Branch')"/>
                        <select t-model="state.createForm.payBranch">
                            <option value="" t-out="this._t('Select branch')"/>
                            <t t-foreach="state.branches" t-as="branch" t-key="'pay-' + branch.id">
                                <option t-att-value="branch.name"><t t-esc="branch.name"/></option>
                            </t>
                        </select>
                        <label t-out="this._t('Salary Type')"/>
                        <select t-model="state.createForm.salaryType">
                            <option value="hour" t-out="this._t('By working hour')"/>
                            <option value="shift" t-out="this._t('By working shift')"/>
                            <option value="month" t-out="this._t('By month')"/>
                        </select>
                        <label t-out="this._t('Salary Amount')"/><input type="text" t-att-value="formatMoney(state.createForm.salaryAmount)" t-on-input="onCreateSalaryInput"/>
                    </div>
                    <div class="sem-actionsRow">
                        <button class="sem-lightBtn" t-on-click="closeCreate" t-out="this._t('Cancel')"/>
                        <button class="sem-primaryBtn" t-on-click="saveCreate" t-out="state.formMode === 'edit' ? this._t('Update Employee') : this._t('Save')"/>
                    </div>
                </div>
            </t>

            <t t-if="state.showFinanceModal">
                <div class="sem-modalBackdrop" t-on-click="closeFinance"/>
                <div class="sem-modal sem-small">
                    <button class="sem-modalClose" t-on-click="closeFinance">×</button>
                    <h3 t-out="this._t('Add Debt and Advance')"/>
                    <div class="sem-formGrid">
                        <label t-out="this._t('Type')"/>
                        <select t-model="state.financeForm.type">
                            <option value="debt" t-out="this._t('Debt')"/>
                            <option value="advance" t-out="this._t('Advance')"/>
                            <option value="payment" t-out="this._t('Payment')"/>
                        </select>
                        <label t-out="this._t('Amount')"/><input type="number" t-model="state.financeForm.amount"/>
                        <label t-out="this._t('Notes')"/><input type="text" t-model="state.financeForm.note"/>
                    </div>
                    <div class="sem-actionsRow">
                        <button class="sem-lightBtn" t-on-click="closeFinance" t-out="this._t('Cancel')"/>
                        <button class="sem-primaryBtn" t-on-click="saveFinance" t-out="this._t('Save')"/>
                    </div>
                </div>
            </t>

            <t t-if="state.showAttendanceModal">
                <div class="sem-modalBackdrop" t-on-click="closeAttendanceModal"/>
                <div class="sem-modal sem-small">
                    <button class="sem-modalClose" t-on-click="closeAttendanceModal">×</button>
                    <h3><t t-esc="getAttendanceModalTitle()"/></h3>
                    <div class="sem-formGrid">
                        <label t-out="this._t('Employee')"/>
                        <div class="sem-modalValue"><t t-esc="state.attendanceForm.employeeName"/></div>
                        <label t-out="this._t('Action')"/>
                        <div class="sem-modalValue"><t t-esc="getAttendanceModalConfirmLabel()"/></div>
                        <label t-out="this._t('Notes')"/>
                        <textarea class="sem-textarea" t-model="state.attendanceForm.note" t-att-placeholder="state.attendanceForm.actionName === 'action_employee_checkout' ? this._t('Add a checkout note...') : this._t('Add a checkin note (optional)...')"/>
                    </div>
                    <div class="sem-actionsRow">
                        <button class="sem-lightBtn" t-on-click="closeAttendanceModal" t-out="this._t('Cancel')"/>
                        <button class="sem-primaryBtn" t-on-click="confirmAttendanceAction"><t t-esc="getAttendanceModalConfirmLabel()"/></button>
                    </div>
                </div>
            </t>
        </div>
    </t>
</templates>
