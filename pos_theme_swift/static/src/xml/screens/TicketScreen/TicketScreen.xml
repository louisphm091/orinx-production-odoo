<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <!-- ✅ Inject sidebar INSIDE the TicketScreen layout -->
    <t t-inherit="point_of_sale.TicketScreen" t-inherit-mode="extension">
        <xpath expr="//div[contains(@class, 'ticket-screen')]" position="inside">
            <div class="ticket-screen-layout d-flex">
                <!-- Sidebar -->
                <div class="main-app">
                    <div class="sidebar">
                        <nav class="main-nav h-100">
                            <ul class="main-menu h-100 m-0 p-0 list-unstyled">
                                <li class="menu-item">
                                    <div class="register-button menu-txt-hld"
        t-on-click="() => this.pos.navigate('ProductScreen')">
                                        <i class="fa fa-ticket menu-icon" />
    <span class="menu-txt">Register</span>
</div>
                                </li>
                            </ul>
                        </nav>
                    </div>
                </div>

            </div>
        </xpath>
    </t>
</templates>
