<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">

  <t t-inherit="point_of_sale.ProductScreen" t-inherit-mode="extension">
    <xpath expr='//div[hasclass("product-screen")]' position="replace">

      <!-- Root -->
      <div class="product-screen d-flex flex-column h-100 bg-100"
           t-att-class="{'flex-grow-1 w-100 mw-100': ui.isSmall}">

        <!-- ===== TOP NAVBAR (replaces sidebar) ===== -->
        <div class="sapphire-navbar">
          <div class="nav-left">
            <div class="navbar-search" id="search-products">
                <Input
                    tModel="[pos, 'searchProductWord']"
                    class="'p-2'"
                    isSmall="ui.isSmall"
                    placeholder="'Tìm hàng hóa (F3)'"
                    icon="{type: 'fa', value: 'fa-search'}"
                    debounceMillis="100"
                />
                </div>

            <button class="nav-btn with-badge"
                    t-on-click="onTicketButtonClick"
                    t-att-badge="orderCount"
                    title="Orders">
              <i class="fa fa-ticket nav-icon" />
              <span class="nav-label">Orders</span>
            </button>

            <button class="nav-btn"
                    t-on-click="onCashMoveButtonClick"
                    title="Cash In/Out">
              <i class="fa fa-money nav-icon" />
              <span class="nav-label">Cash In/Out</span>
            </button>

            <!-- OrderTabs moved from sidebar -->
           <div class="nav-tabs">
                <div class="sapphire-order-tabs d-flex flex-row align-items-center gap-2">
                    <t t-set="tabs" t-value="getOrderTabs()"/>

                    <t t-foreach="tabs" t-as="tab" t-key="tab.key">
                    <button class="order-tab"
                        t-att-class="{'active': tab.order === pos.getOrder()}"
                        t-on-click="() => this.pos.setOrder(tab.order)">

                        <span class="tab-label">
                        <t t-esc="tab.label"/>
                        </span>

                        <span class="tab-close"
                            t-on-click.stop="() => this.pos.removeOrder(tab.order)">
                        ×
                        </span>

                    </button>
                    </t>

                    <button class="order-tab add"
                            title="New Order"
                            t-on-click="() => this.pos.addNewOrder()">
                    <i class="fa fa-plus"/>
                    </button>
                </div>
                </div>
          </div>

          <div class="nav-right">
            <button class="nav-btn"
                    t-on-click="() => pos.closePos()"
                    title="Backend">
              <i class="fa fa-pause nav-icon" />
              <span class="nav-label">Backend</span>
            </button>

            <button class="nav-btn danger"
                    t-on-click="closeSession"
                    title="Logout">
              <i class="fa fa-sign-out nav-icon" />
              <span class="nav-label">Logout</span>
            </button>
              <div class="nav-cashier">
                <CashierName />
            </div>
          </div>
        </div>

        <!-- ===== BODY ===== -->
        <div class="sapphire-body d-flex flex-grow-1 overflow-hidden">
          <!-- RIGHT PANE (Products Area) -->
        <div class="rightpane overflow-auto d-flex flex-grow-1 flex-column w-60"
            t-attf-class="{{ ui.isSmall and pos.mobile_pane !== 'right' ? 'd-none' : '' }}">

        <div class="position-relative d-flex flex-column flex-grow-1 overflow-hidden" t-ref="products-widget">

        <div class="products-area d-flex flex-grow-1 overflow-hidden">

            <!-- LEFT: category list -->
            <div class="category-panel">
            <CategorySelector t-if="!ui.isSmall || !pos.scanning" />
            </div>

            <!-- RIGHT: products -->
            <div class="products-panel flex-grow-1 overflow-hidden d-flex flex-column">

            <BarcodeVideoScanner t-if="pos.scanning" t-props="barcodeVideoScannerProps" />

            <div t-elif="pos.productToDisplayByCateg.length > 0"
                class="product_scroll_bar overflow-y-auto flex-grow-1"
                t-on-scroll="onScroll">

                <div t-foreach="pos.productToDisplayByCateg"
                    t-as="productCateg"
                    t-key="productCateg[0]"
                    class="product-list d-grid gap-1 gap-lg-2 px-2 pt-0 pb-2 mb-5">

                <ProductCard
                    t-foreach="productCateg[1]"
                    t-as="product"
                    t-key="product.id"
                    productId="product.id"
                    product="product"
                    class="pos.productViewMode"
                    name="getProductName(product)"
                    color="product.color || product.pos_categ_ids?.at(-1)?.color"
                    imageUrl="pos.config.show_product_images and this.getProductImage(product)"
                    onClick.bind="() => this.addProductToOrder(product)"
                    t-on-mousedown="(event) => this.onMouseDown(event, product)"
                    t-on-mouseup="longPressHandlers.onMouseUp"
                    t-on-touchstart="(event) => this.onTouchStart(product)"
                    t-on-touchend="longPressHandlers.onTouchEnd"
                    productCartQty="this.state.quantityByProductTmplId[product.id]"
                />
                </div>
            </div>

            <!-- No Product Message (must be sibling of t-elif above) -->
            <div t-else="" class="flex-grow-1 text-center mt-5">
                <p t-if="searchWord">No products found for <b>"<t t-esc="searchWord" />"</b>.</p>

                <div t-elif="!pos.selectedCategory" class="o_view_nocontent">
                <div class="o_nocontent_help">
                    <p class="o_view_nocontent_smiling_face">No Product Yet?</p>
                    <p>Scan a barcode to create automatically, or load our sample data.</p>
                    <p>
                    <button class="btn btn-lg btn-primary me-2"
                            t-on-click="()=> doLoadSampleData.call()"
                            t-att-disabled="doLoadSampleData.status === 'loading' ? 'disabled' : null">
                        <t t-if="doLoadSampleData.status === 'loading'">Loading...</t>
                        <t t-else="">Load Sample</t>
                    </button>
                    <button role="button" class="btn btn-lg btn-secondary"
                            t-on-click="()=>pos.editProduct()">Create Manually</button>
                    </p>
                </div>
                </div>

                <p t-else="">There are no products in this category.</p>
            </div>

            <!-- Search More Button -->
            <div t-if="searchWord" class="search-more-button d-flex justify-content-center m-2">
                <button class="btn btn-primary btn-lg lh-lg" t-on-click="onPressEnterKey">Search more</button>
            </div>

            </div>
        </div>
        </div>

        <!-- Mobile Bottom Bar -->
        <t t-if="ui.isSmall">
            <div class="switchpane d-flex gap-2 p-2 border-top bg-view">
            <button t-if="!pos.scanning"
                    class="btn-switchpane pay-button btn btn-lg flex-grow-1"
                    t-attf-class="{{ currentOrder.isEmpty() ? 'btn-secondary' : 'btn-primary' }}"
                    t-attf-style="{{ currentOrder.isEmpty() ? '' : 'background: linear-gradient(to right bottom, rgb(85, 100, 194), rgb(58, 46, 141)) !important; border-color: rgb(58, 46, 141); color: white !important;' }}"
                    t-on-click="() => this.pos.pay()">
                <span class="d-block">Payment</span>
                <span t-esc="total" />
            </button>

            <button class="btn-switchpane btn btn-secondary review-button flex-grow-1"
                    t-on-click="switchPane">
                <span class="d-block">Cart</span>
                <small><t t-esc="items" /> items</small>
            </button>

            <button t-if="pos.scanning"
                    class="btn-switchpane btn btn-secondary btn-lg flex-grow-1"
                    t-on-click="() => this.pos.scanning = false">
                <span class="d-block">Products</span>
            </button>
            </div>
        </t>
        </div>

          <!-- LEFT PANE (Cart / Summary) -->
        <div class="leftpane d-flex flex-column p-2">

        <OrderSummary />

        <div class="pads">
            <div class="control-buttons d-flex justify-content-between gap-2 w-100 py-2">
            <ControlButtons t-if="!ui.isSmall" onClickMore.bind="displayAllControlPopup" />
            </div>

            <div class="subpads d-flex flex-column gap-2">
            <Numpad
                t-if="!currentOrder?.isEmpty() and pos.getOrder()?.uiState.selected_orderline_uuid"
                class="'d-grid m-n1'"
                buttons="getNumpadButtons()"
                onClick.bind="onNumpadClick"
            />

            <ActionpadWidget
                partner="currentOrder?.getPartner()"
                onClickMore.bind="displayAllControlPopup"
                actionName.translate="Payment"
                actionToTrigger="() => pos.pay()"
                showActionButton="!currentOrder?.isEmpty()"
            />
            </div>
        </div>

        </div>

        </div>

        <!-- Mobile Floating Reminder -->
        <t t-if="ui.isSmall">
          <div class="product-reminder d-flex justify-content-center align-items-center py-1 text-bg-warning bg-opacity-50 fw-bolder"
               t-if="state.showProductReminder"
               t-key="animationKey">
            <span>
              <t t-esc="selectedOrderlineQuantity" />
              <t t-esc="selectedOrderlineDisplayName" />
              <t t-esc="selectedOrderlineTotal" />
            </span>
          </div>
        </t>
        <!-- ===== BOTTOM BAR: Customer / Note (FULL WIDTH) ===== -->
        <div class="sapphire-bottom-bar">
        <button class="sbb-btn"
                t-on-click="() => this.pos.showTempScreen('PartnerListScreen')">
            Customer
        </button>

        <button class="sbb-btn"
                t-on-click="() => this.displayAllControlPopup()">
            Note
        </button>

        <button class="sbb-btn sbb-more"
                t-on-click="() => this.displayAllControlPopup()"
                title="More">
            <i class="fa fa-ellipsis-v"/>
        </button>
        </div>

      </div>
    </xpath>
  </t>

</templates>
