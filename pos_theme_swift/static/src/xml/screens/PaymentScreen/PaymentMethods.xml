<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

  <t t-inherit="point_of_sale.PaymentScreen" t-inherit-mode="extension">

    <!-- WRAP đúng node Methods (dù là component hay t-call) -->
    <xpath expr="(//PaymentScreenMethods | //t[@t-call='point_of_sale.PaymentScreenMethods'])[1]" position="replace">

      <t t-set="order"
         t-value="(pos.getOrder and pos.getOrder()) or (pos.get_order and pos.get_order())"/>

      <div class="sapphire-methods-collapse-wrap mt-2" t-if="order">
        <details class="sapphire-methods-collapse">
          <summary class="sapphire-methods-summary">
            <span class="sms-label">Phương thức</span>
            <span class="sms-current">
              <t t-if="order.selected_paymentline and order.selected_paymentline.payment_method">
                <t t-esc="order.selected_paymentline.payment_method.name"/>
              </t>
              <t t-else="">Chọn…</t>
            </span>
          </summary>

          <div class="sapphire-methods-body">
            <!-- render lại y nguyên node gốc -->
            <PaymentScreenMethods/>
          </div>
        </details>
      </div>

    </xpath>

  </t>

</templates>
