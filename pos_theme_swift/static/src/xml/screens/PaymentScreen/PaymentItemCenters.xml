<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">

  <t t-inherit="point_of_sale.PaymentScreen" t-inherit-mode="extension">

    <!-- Replace center-content by our table -->
    <xpath expr="//div[hasclass('payment-screen')]//div[hasclass('center-content')][1]" position="replace">
      <div class="center-content sapphire-items-table-wrap">

        <t t-set="order" t-value="this.sppOrder()"/>
        <t t-set="lines" t-value="order and this.sppOrderlines(order) or []"/>
        <div class="sit-table-card">
          <table class="sit-table" t-if="lines.length">
            <thead>
              <tr>
                <th class="col-idx">#</th>
                <th class="col-name" t-out="this._t('Product')"/>
                <th class="col-unit" t-out="this._t('Unit Price')"/>
                <th class="col-uom" t-out="this._t('UoM')"/>
                <th class="col-qty" t-out="this._t('Qty')"/>
                <th class="col-total" t-out="this._t('Total')"/>
              </tr>
            </thead>

            <tbody>
              <t t-foreach="lines" t-as="line" t-key="this.sppLineKey(line, this.sppIndexOf(line))">
                <tr class="sit-row">
                  <!-- 1) STT + delete -->
                  <td class="col-idx">
                    <div class="idx-wrap">
                      <span class="idx-num"><t t-esc="this.sppIndexOf(line) + 1"/></span>
                      <button type="button"
                              class="idx-del"
                              title="Delete"
                              t-att-title="this._t('Delete')"
                              t-on-click.stop="() => this.sppRemoveLine(line)">
                        <i class="fa fa-trash"/>
                      </button>
                    </div>
                  </td>

                  <!-- 2) Name -->
                  <td class="col-name">
                    <div class="name-wrap">
                      <div class="name-text" t-att-title="this.sppLineName(line)">
                        <t t-esc="this.sppLineName(line)"/>
                      </div>
                    </div>
                  </td>

                  <!-- 3) Unit -->
                  <td class="col-unit">
                    <t t-esc="env.utils.formatCurrency(this.sppLineUnitPrice(line))"/>
                  </td>
                  <td class="col-uom">
                    <select class="sapphire-uom-select"
                            t-on-change="(ev) => this.sppOnUomChange(line, ev)">
                      <t t-foreach="this.sppGetLineUoms(line)" t-as="uom" t-key="uom.id">
                        <option t-att-value="uom.id" t-att-selected="uom.id == this.sppLineUomId(line)">
                          <t t-esc="uom.name"/>
                        </option>
                      </t>
                    </select>
                  </td>

                  <!-- 4) Qty control -->
                    <td class="col-qty">
                    <div class="qty-control">
                        <button type="button"
                                class="qty-btn"
                                t-on-click.stop="() => this.sppDecQty(line)">
                        -
                        </button>

                        <span class="qty-num">
                        <t t-esc="this.sppLineQty(line)"/>
                        </span>

                        <button type="button"
                                class="qty-btn"
                                t-on-click.stop="() => this.sppIncQty(line)">
                        +
                        </button>
                    </div>
                    </td>

                  <!-- 5) Total -->
                  <td class="col-total">
                    <span class="total-money">
                      <t t-esc="env.utils.formatCurrency(this.sppLineTotal(line))"/>
                    </span>
                  </td>
                </tr>
              </t>
            </tbody>
          </table>

          <div class="sit-empty" t-else="" t-out="this._t('No products yet')"/>
        </div>

      </div>
    </xpath>

  </t>

</templates>
