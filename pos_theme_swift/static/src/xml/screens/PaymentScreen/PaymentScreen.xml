<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">

  <t t-inherit="point_of_sale.PaymentScreen" t-inherit-mode="extension">

    <!-- 1) Insert navbar BEFORE main-content so it appears on top on desktop -->
    <xpath expr="//div[contains(@class,'payment-screen')]/div[contains(@class,'main-content')][1]" position="before">
      <div class="sapphire-navbar sapphire-navbar--payment">
        <div class="nav-left">
          <div class="navbar-search" id="search-products">
            <i class="fa fa-search scp-search-icon"/>
            <input class="scp-search-input" type="search" placeholder="Tìm hàng hóa (F3)"/>
          </div>

          <button class="nav-btn with-badge" t-on-click="onTicketButtonClick" t-att-badge="orderCount">
            <i class="fa fa-ticket nav-icon"/>
            <span class="nav-label">Orders</span>
          </button>

          <button class="nav-btn" t-on-click="onCashMoveButtonClick">
            <i class="fa fa-money nav-icon"/>
            <span class="nav-label">Cash In/Out</span>
          </button>

          <div class="nav-tabs">
            <div class="sapphire-order-tabs d-flex flex-row align-items-center gap-2">
              <t t-set="tabs" t-value="getOrderTabs()"/>
              <t t-foreach="tabs" t-as="tab" t-key="tab.key">
                <button class="order-tab"
                        t-att-class="{'active': tab.order === pos.getOrder()}"
                        t-on-click="() => this.pos.setOrder(tab.order)">
                  <span class="tab-label"><t t-esc="tab.label"/></span>
                  <span class="tab-close" t-on-click.stop="() => this.pos.removeOrder(tab.order)">×</span>
                </button>
              </t>
              <button class="order-tab add" t-on-click="() => this.pos.addNewOrder()">
                <i class="fa fa-plus"/>
              </button>
            </div>
          </div>
        </div>

        <div class="nav-right">
          <button class="nav-btn" t-on-click="() => pos.closePos()">
            <i class="fa fa-pause nav-icon"/>
            <span class="nav-label">Backend</span>
          </button>

          <button class="nav-btn danger" t-on-click="closeSession">
            <i class="fa fa-sign-out nav-icon"/>
            <span class="nav-label">Logout</span>
          </button>

          <div class="nav-cashier">
            <CashierName/>
          </div>
        </div>
      </div>
    </xpath>

    <!-- 2) Add a class flag on payment-screen to apply padding -->
    <xpath expr="//div[contains(@class,'payment-screen')]" position="attributes">
      <attribute name="class" add=" o_sapphire_payment_with_navbar " separator=" "/>
    </xpath>

  </t>
</templates>
