<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

  <t t-name="sale_planning.AnalyticsDashboard" owl="1">
    <div class="sp_analytics p-3 o_action">

      <!-- Header -->
      <div class="sp_topbar d-flex justify-content-between align-items-start gap-3">
        <div>
          <div class="sp_title">
            <span class="sp_logo"><i class="fa fa-instagram"/></span>
            <t t-out="this._t('ANALYTICS &amp; REPORTS')"/>
          </div>
          <div class="sp_subtitle" t-out="this._t('Aggregate business performance, user behavior and compare plan vs actual')"/>
        </div>

        <div class="d-flex gap-2 align-items-center flex-wrap sp_filters">
          <!-- Category Filter -->
          <select class="form-select sp_pill w-auto" t-on-change="(ev) => this.onFilterChange('category_id', ev.target.value)">
              <option value=""><t t-out="this._t('Category')"/>: <t t-out="this._t('All')"/></option>
              <t t-foreach="state.categories" t-as="cat" t-key="cat.id">
                  <option t-att-value="cat.id" t-att-selected="state.filters.category_id == cat.id"><t t-esc="cat.name"/></option>
              </t>
          </select>

          <!-- Branch Filter -->
          <select class="form-select sp_pill w-auto" t-on-change="(ev) => this.onFilterChange('warehouse_id', ev.target.value)">
              <option value=""><t t-out="this._t('Branch')"/>: <t t-out="this._t('All')"/></option>
              <t t-foreach="state.warehouses" t-as="wh" t-key="wh.id">
                  <option t-att-value="wh.id" t-att-selected="state.filters.warehouse_id == wh.id"><t t-esc="wh.name"/></option>
              </t>
          </select>

          <div class="sp_actions d-flex gap-2">
            <button class="btn btn-light sp_pill" type="button"><i class="fa fa-calendar me-1"/> <t t-out="this._t('Month')"/></button>
            <button class="btn btn-light sp_pill" type="button"><i class="fa fa-wifi me-1"/> <t t-out="this._t('Online')"/></button>
            <button class="btn btn-outline-secondary sp_pill" type="button"><i class="fa fa-download me-1"/> <t t-out="this._t('Export CSV')"/></button>
          </div>
        </div>
      </div>

      <div class="mt-3">
        <t t-if="state.loading">
          <div class="alert alert-info" t-out="this._t('Loading data...')"/>
        </t>
        <t t-elif="state.error">
          <div class="alert alert-danger"><t t-esc="state.error"/></div>
        </t>
        <t t-else="">

          <!-- KPI cards -->
          <div class="row g-3 sp_cards">
            <div class="col-12 col-lg-3">
              <div class="card sp_card p-3">
                <div class="d-flex justify-content-between">
                  <div>
                    <div class="sp_card_title" t-out="this._t('User Behavior')"/>
                    <div class="sp_card_value">
                      <t t-esc="fmtNumber(state.kpis.user_behavior.pv)"/> /
                      <t t-esc="fmtNumber(state.kpis.user_behavior.uu)"/>
                    </div>
                    <div class="sp_card_meta">
                      <span class="text-success"><t t-esc="state.kpis.user_behavior.delta_percent"/></span> <t t-out="this._t('vs previous period')"/>
                    </div>
                  </div>
                  <div class="sp_card_icon"><i class="fa fa-users"/></div>
                </div>
              </div>
            </div>

            <div class="col-12 col-lg-3">
              <div class="card sp_card p-3">
                <div class="d-flex justify-content-between">
                  <div>
                    <div class="sp_card_title" t-out="this._t('Revenue')"/>
                    <div class="sp_card_value"><t t-esc="fmtMoneyVND(state.kpis.revenue.value)"/></div>
                    <div class="sp_card_meta"><t t-out="this._t('Growth')"/> <t t-esc="state.kpis.revenue.growth_percent"/>%</div>
                  </div>
                  <div class="sp_card_icon"><i class="fa fa-line-chart"/></div>
                </div>
              </div>
            </div>

            <div class="col-12 col-lg-3">
              <div class="card sp_card p-3">
                <div class="d-flex justify-content-between">
                  <div>
                    <div class="sp_card_title" t-out="this._t('Profit')"/>
                    <div class="sp_card_value"><t t-esc="fmtMoneyVND(state.kpis.profit.value)"/></div>
                    <div class="sp_card_meta"><t t-out="this._t('Growth')"/> <t t-esc="state.kpis.profit.growth_percent"/>%</div>
                  </div>
                  <div class="sp_card_icon"><i class="fa fa-database"/></div>
                </div>
              </div>
            </div>

            <div class="col-12 col-lg-3">
              <div class="card sp_card p-3">
                <div class="d-flex justify-content-between">
                  <div>
                    <div class="sp_card_title"><t t-esc="state.kpis.kpi_over.delta_percent"/> <t t-out="this._t('vs plan')"/></div>
                    <div class="sp_card_value" t-out="this._t('Categories exceeded KPI')"/>
                    <div class="sp_card_meta">—</div>
                  </div>
                  <div class="sp_card_icon"><i class="fa fa-bar-chart"/></div>
                </div>
              </div>
            </div>
          </div>

          <!-- Middle row -->
          <div class="row g-3 mt-1">
            <!-- Behavior line chart -->
            <div class="col-12 col-lg-7">
              <div class="card sp_panel p-3 h-100">
                <div class="sp_panel_head d-flex justify-content-between align-items-center">
                  <div class="sp_panel_title" t-out="this._t('User Behavior Analysis')"/>
                  <i class="fa fa-ellipsis-h text-muted"/>
                </div>
                <div class="sp_chart_wrap" style="height:260px;">
                  <canvas t-ref="behaviorChart"/>
                </div>
              </div>
            </div>

            <!-- Revenue by category -->
            <div class="col-12 col-lg-3">
              <div class="card sp_panel p-3 h-100">
                <div class="sp_panel_head d-flex justify-content-between align-items-center">
                  <div class="sp_panel_title" t-out="this._t('Revenue by Category')"/>
                  <i class="fa fa-ellipsis-h text-muted"/>
                </div>

                <div class="sp_big_number mt-1">
                  <t t-esc="state.revenue_bar.headline"/>
                </div>

                <div class="sp_chart_wrap" style="height:140px;">
                  <canvas t-ref="revenueBarChart"/>
                </div>

                <div class="mt-2">
                  <t t-foreach="state.revenue_by_category" t-as="c" t-key="c.key">
                    <div class="d-flex justify-content-between align-items-center sp_row">
                      <div class="d-flex align-items-center gap-2">
                        <span class="sp_dot" t-att-style="'background:'+ (c.color || 'rgba(16,185,129,0.9)')"/>
                        <span class="sp_row_name"><t t-esc="c.name"/></span>
                      </div>
                      <span class="sp_row_val"><t t-esc="c.value"/> M</span>
                    </div>
                  </t>
                </div>
              </div>
            </div>

            <!-- Donut -->
            <div class="col-12 col-lg-2">
              <div class="card sp_panel p-3 h-100">
                <div class="sp_panel_head d-flex justify-content-between align-items-center">
                  <div class="sp_panel_title" t-out="this._t('Full Price / Sale')"/>
                  <i class="fa fa-ellipsis-h text-muted"/>
                </div>

                <div class="mt-1">
                  <div class="sp_big_percent">
                    <t t-esc="state.pricing_mix.full_price"/>%
                    <span class="text-muted" t-out="this._t('full price')"/>
                  </div>
                  <div class="text-muted small">
                    <t t-esc="state.pricing_mix.sale"/>% <t t-out="this._t('sale')"/>
                  </div>
                </div>

                <div class="sp_chart_wrap mt-2" style="height:160px;">
                  <canvas t-ref="donutChart"/>
                </div>

                <div class="text-muted small mt-2">
                  <t t-esc="state.pricing_mix.note"/>
                </div>
              </div>
            </div>
          </div>

          <!-- Bottom row -->
          <div class="row g-3 mt-1">
            <div class="col-12 col-lg-6">
              <div class="card sp_panel p-3">
                <div class="sp_panel_head d-flex justify-content-between align-items-center">
                  <div class="sp_panel_title" t-out="this._t('Plan / Actual')"/>
                  <i class="fa fa-ellipsis-h text-muted"/>
                </div>

                <div class="table-responsive">
                  <table class="table table-sm align-middle mb-0 sp_table">
                    <thead class="text-muted">
                      <tr>
                        <th t-out="this._t('Product')"/>
                        <th t-out="this._t('Category')"/>
                        <th class="text-end">PV</th>
                        <th class="text-end">UU</th>
                        <th class="text-end" t-out="this._t('Revenue')"/>
                        <th class="text-end" t-out="this._t('Full Price')"/>
                      </tr>
                    </thead>
                    <tbody>
                      <t t-foreach="state.plan_actual_rows" t-as="r" t-key="r.key">
                        <tr>
                          <td class="fw-semibold"><t t-esc="r.name"/></td>
                          <td class="text-muted"><t t-esc="r.category"/></td>
                          <td class="text-end"><t t-esc="fmtNumber(r.pv)"/></td>
                          <td class="text-end"><t t-esc="fmtNumber(r.uu)"/></td>
                          <td class="text-end"><t t-esc="r.revenue"/></td>
                          <td class="text-end"><span class="sp_pill_badge"><t t-esc="r.full_price"/></span></td>
                        </tr>
                      </t>
                    </tbody>
                  </table>
                </div>
              </div>
            </div>

            <div class="col-12 col-lg-6">
              <div class="card sp_panel p-3">
                <div class="sp_panel_head d-flex justify-content-between align-items-center">
                  <div class="sp_panel_title" t-out="this._t('Charts &amp; Data Table')"/>
                  <div class="sp_search">
                    <i class="fa fa-search text-muted"/>
                    <input class="form-control form-control-sm" t-att-placeholder="this._t('Search')"
                           t-model="state.search"/>
                  </div>
                </div>

                <div class="table-responsive">
                  <table class="table table-sm align-middle mb-0 sp_table">
                    <thead class="text-muted">
                      <tr>
                        <th t-out="this._t('Product')"/>
                        <th t-out="this._t('Category')"/>
                        <th class="text-end">PV</th>
                        <th class="text-end">UU</th>
                        <th class="text-end" t-out="this._t('Revenue')"/>
                        <th class="text-end" t-out="this._t('Sale')"/>
                      </tr>
                    </thead>
                    <tbody>
                      <t t-foreach="filteredDataRows()" t-as="r" t-key="r.key">
                        <tr>
                          <td class="fw-semibold"><t t-esc="r.name"/></td>
                          <td class="text-muted"><t t-esc="r.category"/></td>
                          <td class="text-end"><t t-esc="fmtNumber(r.pv)"/></td>
                          <td class="text-end"><t t-esc="fmtNumber(r.uu)"/></td>
                          <td class="text-end"><t t-esc="r.revenue"/></td>
                          <td class="text-end">
                            <span class="sp_sale_badge"><t t-esc="r.sale"/>%</span>
                          </td>
                        </tr>
                      </t>
                    </tbody>
                  </table>
                </div>

              </div>
            </div>
          </div>

        </t>
      </div>

    </div>
  </t>

</templates>
