<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

  <t t-name="sale_planning.ReplenishmentDashboard" owl="1">
    <div class="sp_rep p-3">

            <!-- HEADER -->
      <div class="sp_rep_header d-flex justify-content-between align-items-start mb-3">
        <div>
          <div class="sp_rep_title" t-out="this._t('REPLENISHMENT MANAGEMENT')"/>
          <div class="sp_rep_sub text-muted" t-out="this._t('Track – Approve – Control replenishment suggestions based on forecast &amp; inventory')"/>
        </div>

        <div class="d-flex align-items-center gap-2">
          <!-- Category Filter -->
          <select class="form-select sp_pill w-auto" t-on-change="(ev) => this.onFilterChange('category_id', ev.target.value)">
              <option value=""><t t-out="this._t('Category')"/>: <t t-out="this._t('All')"/></option>
              <t t-foreach="state.categories" t-as="cat" t-key="cat.id">
                  <option t-att-value="cat.id" t-att-selected="state.filters.category_id == cat.id"><t t-esc="cat.name"/></option>
              </t>
          </select>

          <!-- Branch Filter -->
          <select class="form-select sp_pill w-auto" t-on-change="(ev) => this.onFilterChange('warehouse_id', ev.target.value)">
              <option value=""><t t-out="this._t('Branch')"/>: <t t-out="this._t('All')"/></option>
              <t t-foreach="state.warehouses" t-as="wh" t-key="wh.id">
                  <option t-att-value="wh.id" t-att-selected="state.filters.warehouse_id == wh.id"><t t-esc="wh.name"/></option>
              </t>
          </select>

          <button class="btn sp_pill" type="button"><t t-out="this._t('Month')"/> <i class="fa fa-angle-down ms-1"/></button>
          <button class="btn sp_icon_btn" type="button"><i class="fa fa-envelope-o"/></button>
          <button class="btn sp_icon_btn" type="button"><i class="fa fa-angle-down"/></button>
        </div>
      </div>

            <!-- TOP ACTIONS -->
      <div class="d-flex justify-content-end gap-2 mb-3 mt-1">
        <button class="btn btn-light border p-2 px-3 sp_pill d-flex align-items-center gap-2 shadow-sm" type="button" t-on-click="batchCreateMO">
           <i class="fa fa-briefcase text-success"></i>
           <span class="fw-semibold" t-out="this._t('Order Planning')"/>
        </button>
        <button class="btn sp_pill" type="button"><i class="fa fa-search me-1"/> <t t-out="this._t('Article Page')"/></button>
        <button class="btn sp_pill" type="button"><i class="fa fa-download me-1"/> <t t-out="this._t('Export CSV')"/></button>
      </div>

      <t t-if="state.loading">
        <div class="alert alert-info"><t t-out="this._t('Loading data...')"/></div>
      </t>
      <t t-elif="state.error">
        <div class="alert alert-danger"><t t-esc="state.error"/></div>
      </t>
      <t t-else="">

                <!-- KPI ROW -->
        <div class="row g-3 mb-3 align-items-stretch">
          <div class="col-12 col-lg-3">
            <div class="card sp_card p-3 h-100 d-flex flex-column">
              <div class="d-flex justify-content-between align-items-start">
                <div>
                  <div class="sp_kpi_label" t-out="this._t('Total Suggestions')"/>
                  <div class="sp_kpi_value"><t t-esc="state.kpis.total_suggestions"/> <t t-out="this._t('suggestions')"/></div>
                  <div class="sp_kpi_hint text-muted">
                    <i class="fa fa-arrow-up text-success me-1"/><t t-esc="state.kpis.delta_vs_last_week"/> <t t-out="this._t('vs last week')"/>
                  </div>
                </div>
                <button class="btn btn-sm btn-light rounded-circle" type="button" style="width:32px;height:32px;">
                  <i class="fa fa-ellipsis-h"/>
                </button>
              </div>
            </div>
          </div>

          <div class="col-12 col-lg-3">
            <div class="card sp_card p-3 sp_card_image h-100 d-flex flex-column">
              <div class="sp_kpi_label"><i class="fa fa-exclamation-triangle text-warning me-1"/><t t-out="this._t('Out of Stock Risk')"/></div>
              <div class="sp_kpi_value"><t t-esc="state.kpis.risk_skus"/> <t t-out="this._t('SKUs')"/></div>
              <div class="sp_kpi_hint text-muted"><t t-esc="state.kpis.risk_hint"/></div>
            </div>
          </div>

          <div class="col-12 col-lg-3">
            <div class="card sp_card p-3 sp_card_image h-100 d-flex flex-column">
              <div class="sp_kpi_label" t-out="this._t('Pending Approval')"/>
              <div class="sp_kpi_value"><t t-esc="state.kpis.pending"/> <t t-out="this._t('suggestions')"/></div>
              <div class="sp_kpi_hint text-muted"><t t-esc="state.kpis.pending_hint"/></div>
            </div>
          </div>

          <div class="col-12 col-lg-3">
            <div class="card sp_card p-3 sp_card_image h-100 d-flex flex-column">
              <div class="sp_kpi_label" t-out="this._t('Ordered')"/>
              <div class="sp_kpi_value"><t t-esc="state.kpis.ordered"/> <t t-out="this._t('orders')"/></div>
              <div class="sp_kpi_hint text-muted"><t t-esc="state.kpis.ordered_hint"/></div>
            </div>
          </div>
        </div>

                <!-- MAIN: TABLE + DETAIL PANEL -->
        <div class="row g-3">
          <div class="col-12 col-lg-8">
            <div class="card sp_card p-3">
              <div class="d-flex justify-content-between align-items-center mb-2">
                <div class="sp_section_title" t-out="this._t('Replenishment Suggestion List')"/>

              <div class="d-flex align-items-center gap-2">
                <div class="sp_search">
                  <i class="fa fa-search"/>
                  <input
                    t-att-value="state.filters.search"
                    t-att-placeholder="this._t('Search...')"
                    t-on-input="updateSearch"
                  />
                </div>
                <button class="btn sp_pill" type="button"><t t-out="this._t('All')"/> <i class="fa fa-angle-down ms-1"/></button>
              </div>
              </div>

              <div class="d-flex gap-2 mb-2">
                <button class="btn sp_pill" type="button"><t t-out="this._t('Status: All')"/> <i class="fa fa-angle-down ms-1"/></button>
                <button class="btn sp_pill" type="button"><t t-out="this._t('Filter')"/> <i class="fa fa-angle-down ms-1"/></button>
              </div>

              <div class="table-responsive">
                <table class="table table-sm align-middle mb-0 sp_table">
                  <thead class="text-muted small">
                    <tr>
                      <th>Mã hàng / Sản phẩm</th>
                      <th>Danh mục</th>
                      <th>Chi nhánh</th>
                      <th class="text-end">Nhu cầu (30n)</th>
                      <th class="text-end">Nhu cầu dự báo</th>
                      <th class="text-end">Tồn kho hiện tại</th>
                      <th class="text-end">Ngưỡng tồn kho</th>
                      <th class="text-end">SL bổ sung gợi ý</th>
                      <th class="text-end">Trạng thái</th>
                    </tr>
                  </thead>
                  <tbody>
                    <t t-set="rows" t-value="paginatedRows()"/>
                    <t t-if="!rows.length">
                      <tr><td colspan="7" class="text-muted" t-out="this._t('No data')"/></tr>
                    </t>
                    <t t-else="">
                      <t t-foreach="rows" t-as="r" t-key="r.key">
                        <tr t-att-class="state.filters.selected_key === r.key ? 'sp_row_active' : ''"
                            t-on-click="() => this.selectRow(r.key)">
                          <td class="fw-semibold">
                            <div class="d-flex align-items-center gap-2">
                              <div class="sp_thumb">👕</div>
                              <div>
                                <div><t t-esc="r.sku_name"/></div>
                              </div>
                            </div>
                          </td>
                          <td><t t-esc="r.category"/></td>
                          <td><t t-esc="r.warehouse"/></td>
                          <td class="text-end"><t t-esc="r.demand_qty"/></td>
                          <td class="text-end fw-bold text-primary"><t t-esc="r.forecast_qty"/></td>
                          <td class="text-end"><t t-esc="r.onhand"/></td>
                          <td class="text-end"><t t-esc="r.threshold"/></td>
                          <td class="text-end fw-bold text-success"><t t-esc="r.suggest_qty"/></td>
                          <td class="text-end">
                            <span t-att-class="badgeClass(r.state)"><t t-esc="this._t(badgeText(r.state))"/></span>
                          </td>
                        </tr>
                      </t>
                    </t>
                  </tbody>
                </table>
              </div>

              <div class="d-flex justify-content-between align-items-center mt-2 text-muted small">
                <div><t t-esc="state.pagination.currentPage"/> / <t t-esc="getTotalPages()"/> <t t-out="this._t('page')"/></div>
                <div class="d-flex gap-1">
                  <button class="btn btn-sm btn-light border-0" t-on-click="() => this.changePage(state.pagination.currentPage - 1)" t-att-disabled="state.pagination.currentPage === 1">‹</button>
                  <t t-foreach="getPageNumbers()" t-as="page" t-key="page_index">
                    <button
                      t-if="page !== '...'"
                      class="btn btn-sm border-0"
                      t-att-class="state.pagination.currentPage === page ? 'btn btn-primary fw-bold px-3' : 'btn-light'"
                      t-on-click="() => this.changePage(page)"
                    >
                      <t t-esc="page"/>
                    </button>
                    <span t-else="" class="px-2 text-muted">...</span>
                  </t>
                  <button class="btn btn-sm btn-light border-0" t-on-click="() => this.changePage(state.pagination.currentPage + 1)" t-att-disabled="state.pagination.currentPage === getTotalPages()">›</button>
                </div>
              </div>
            </div>
          </div>

          <!-- DETAIL PANEL -->
          <div class="col-12 col-lg-4">
            <div class="card sp_card p-3 sp_side">
              <div class="d-flex justify-content-between align-items-center mb-2">
                <div class="text-muted small" t-out="this._t('Replenishment Suggestion')"/>
                <button class="btn btn-sm btn-light rounded-circle" type="button" style="width:32px;height:32px;">
                  <i class="fa fa-times"/>
                </button>
              </div>

              <div class="sp_side_title mb-2">
                <t t-esc="state.detail.title"/>
              </div>

              <div class="d-flex justify-content-between align-items-start mb-3">
                <div class="text-muted small">
                  <div><t t-esc="state.detail.category"/></div>
                  <div><t t-esc="state.detail.season"/></div>
                </div>
                <div class="sp_side_img">
                  <t t-if="state.detail.image_url">
                    <img
                      t-att-src="state.detail.image_url"
                      t-att-alt="state.detail.title || 'Product image'"
                    />
                  </t>
                  <t t-else=""><span class="sp_side_img_placeholder">🧺</span></t>
                </div>
              </div>

              <div class="sp_block_title" t-out="this._t('Proposal Analysis')"/>
              <div class="sp_kv">
                <div class="sp_kv_row">
                  <div class="text-muted" t-out="this._t('Current Stock')"/>
                  <div class="fw-semibold"><t t-if="state.detail.analysis" t-esc="state.detail.analysis.onhand || 0"/><t t-else="">0</t></div>
                </div>
                <div class="sp_kv_row">
                  <div class="text-muted" t-out="this._t('Threshold')"/>
                  <div class="fw-semibold"><t t-if="state.detail.analysis" t-esc="state.detail.analysis.reorder_point || 0"/><t t-else="">0</t></div>
                </div>
                <div class="sp_kv_row">
                  <div class="text-muted" t-out="this._t('Suggested Replenishment')"/>
                  <div class="sp_tag_plus">+<t t-if="state.detail.analysis" t-esc="state.detail.analysis.suggest_qty || 0"/><t t-else="">0</t></div>
                </div>
              </div>

              <div class="sp_block_title mt-3" t-out="this._t('Replenishment Reason')"/>
              <div class="text-muted small">
                <t t-esc="state.detail.reason"/>
              </div>

              <div class="pt-3 d-flex gap-2">
                <button
                  class="btn btn-success flex-fill"
                  type="button"
                  t-att-disabled="!state.detail.product_id"
                  t-on-click="approveReplenishment"
                  t-out="this._t('Approve')"
                />
                <button
                  class="btn btn-outline-secondary flex-fill"
                  type="button"
                  t-att-disabled="!state.detail.product_id"
                  t-on-click="editSelectedQuantity"
                  t-out="this._t('Edit Quantity')"
                />
              </div>
              <div class="text-end mt-2">
                <button class="btn btn-link text-danger" type="button" t-out="this._t('Reject')"/>
              </div>
            </div>
          </div>

        </div>
      </t>
    </div>
  </t>
</templates>
