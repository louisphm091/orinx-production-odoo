<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
  <t t-name="sale_planning.Dashboard" owl="1">
    <div class="sp_wrap p-3">

      <!-- TOP BAR -->
      <div class="sp_topbar d-flex justify-content-between align-items-center mb-2">
        <div>
          <div class="sp_title" t-out="this._t('Supply / Purchase Plan')"/>
          <div class="sp_subtitle text-muted" t-out="this._t('Plan and track purchase/supply plans based on demand and production plans')"/>
        </div>

        <div class="d-flex align-items-center gap-2">
          <button class="btn btn-light sp_pill" type="button"><t t-out="this._t('SKU / SKU Group')"/></button>
          <button class="btn btn-primary sp_btn" t-on-click="load" type="button">
            <i class="fa fa-refresh me-1"/> <t t-out="this._t('Refresh')"/>
          </button>
        </div>
      </div>

      <!-- FILTER ROW -->
      <div class="sp_filters d-flex flex-wrap gap-2 align-items-center mb-3">
        <!-- Category Filter -->
        <select class="form-select sp_pill w-auto" t-on-change="(ev) => this.onFilterChange('category_id', ev.target.value)">
            <option value=""><t t-out="this._t('Category')"/>: <t t-out="this._t('All')"/></option>
            <t t-foreach="state.categories" t-as="cat" t-key="cat.id">
                <option t-att-value="cat.id" t-att-selected="state.filters.category_id == cat.id"><t t-esc="cat.name"/></option>
            </t>
        </select>

        <!-- Branch Filter -->
        <select class="form-select sp_pill w-auto" t-on-change="(ev) => this.onFilterChange('warehouse_id', ev.target.value)">
            <option value=""><t t-out="this._t('Branch')"/>: <t t-out="this._t('All')"/></option>
            <t t-foreach="state.warehouses" t-as="wh" t-key="wh.id">
                <option t-att-value="wh.id" t-att-selected="state.filters.warehouse_id == wh.id"><t t-esc="wh.name"/></option>
            </t>
        </select>

        <!-- Time Filter -->
        <select class="form-select sp_pill w-auto" t-on-change="(ev) => this.onFilterChange('time_range', ev.target.value)">
            <t t-foreach="state.time_options" t-as="opt" t-key="opt.id">
                <option t-att-value="opt.id" t-att-selected="state.filters.time_range == opt.id"><t t-esc="opt.name"/></option>
            </t>
        </select>

        <div class="ms-auto">
          <button class="btn btn-success sp_btn" type="button"
                  t-on-click="onCreateSupplyPlan"
                  t-att-disabled="state.creating">
            <t t-if="state.creating"><i class="fa fa-spinner fa-spin me-1"/></t>
            <t t-else=""><i class="fa fa-plus me-1"/></t>
            <t t-out="this._t('Create Supply Plan')"/>
          </button>
        </div>
      </div>

      <t t-if="state.loading">
        <div class="alert alert-info" t-out="this._t('Loading data...')"/>
      </t>
      <t t-elif="state.error">
        <div class="alert alert-danger"><t t-esc="state.error"/></div>
      </t>
      <t t-else="">

        <!-- KPI CARDS -->
        <div class="row g-3 mb-3">
          <div class="col-12 col-md-3">
            <div class="card sp_card p-3 h-100">
              <div class="d-flex justify-content-between align-items-start">
                <div class="sp_card_title" t-out="this._t('Total Supply Demand')"/>
                <i class="fa fa-ellipsis-h text-muted"/>
              </div>
              <div class="sp_kpi_value">
                <t t-esc="formatNumber(state.kpis.total_supply_need)"/> <span class="sp_kpi_unit" t-out="this._t('units')"/>
              </div>
              <div class="sp_kpi_hint text-muted">
                +<t t-esc="state.kpis.growth_percent"/>% <t t-out="this._t('vs previous period')"/>
              </div>
            </div>
          </div>

          <div class="col-12 col-md-3">
            <div class="card sp_card p-3 h-100">
              <div class="d-flex justify-content-between align-items-start">
                <div class="sp_card_title" t-out="this._t('Planned Purchase')"/>
                <i class="fa fa-ellipsis-h text-muted"/>
              </div>
              <div class="sp_kpi_value">
                <t t-esc="formatNumber(state.kpis.purchase_plan_qty)"/> <span class="sp_kpi_unit" t-out="this._t('units')"/>
              </div>
              <div class="sp_kpi_hint text-muted">74% <t t-out="this._t('of demand')"/></div>
            </div>
          </div>

          <div class="col-12 col-md-3">
            <div class="card sp_card p-3 h-100 sp_warn">
              <div class="d-flex justify-content-between align-items-start">
                <div class="sp_card_title" t-out="this._t('Out of Stock Risk')"/>
                <i class="fa fa-ellipsis-h text-muted"/>
              </div>
              <div class="sp_kpi_value">
                <t t-esc="formatNumber(state.kpis.risk_sku_count)"/> <span class="sp_kpi_unit" t-out="this._t('SKUs')"/>
              </div>
              <div class="sp_kpi_hint text-muted" t-out="this._t('Expected shortage in 14 days')"/>
            </div>
          </div>

          <div class="col-12 col-md-3">
            <div class="card sp_card p-3 h-100">
              <div class="d-flex justify-content-between align-items-start">
                <div class="sp_card_title" t-out="this._t('Waiting for Delivery')"/>
                <i class="fa fa-ellipsis-h text-muted"/>
              </div>
              <div class="sp_kpi_value">
                <t t-esc="formatNumber(state.kpis.waiting_orders)"/> <span class="sp_kpi_unit" t-out="this._t('orders')"/>
              </div>
              <div class="sp_kpi_hint text-muted" t-out="this._t('Updated today')"/>
            </div>
          </div>
        </div>

        <!-- MAIN ROW -->
        <div class="row g-3 mb-3">
          <div class="col-12 col-lg-8">
            <div class="card sp_card p-3 h-100">
              <div class="d-flex justify-content-between align-items-center mb-2">
                <div class="fw-semibold" t-out="this._t('Purchase Recommendations')"/>
                <div class="text-muted small"><t t-out="this._t('Updated:')"/> <t t-esc="state.kpis.last_update"/></div>
              </div>
              <div class="position-relative sp_chart_box">
                <canvas t-ref="mainChart"/>
              </div>
            </div>
          </div>

          <div class="col-12 col-lg-4">
            <div class="card sp_card p-3 h-100">
              <div class="d-flex justify-content-between align-items-center mb-2">
                <div class="fw-semibold" t-out="this._t('Inventory Forecast')"/>
                <i class="fa fa-ellipsis-h text-muted"/>
              </div>

              <div class="position-relative sp_mini_chart_box">
                <canvas t-ref="inventoryChart"/>
              </div>

              <t t-set="inv" t-value="state.inventory_forecast or {}"/>

            <div class="mt-2">
                <div class="fw-semibold">
                    <t t-esc="inv.hint and inv.hint.sku_name or '-'"/>
                </div>

                <div class="text-muted small">
                    <t t-esc="inv.hint and inv.hint.message or ''"/>
                </div>
            </div>

              <div class="mt-2 pt-2 border-top text-muted small">
                <i class="fa fa-check-circle text-success me-1"/>
                <t t-esc="inv.growth_note || ''"/>
              </div>
            </div>
          </div>
        </div>

        <!-- SECOND ROW -->
        <div class="row g-3">
          <div class="col-12 col-lg-4">
            <div class="card sp_card p-3 h-100">
              <div class="d-flex justify-content-between align-items-center mb-2">
                <div class="fw-semibold" t-out="this._t('Forecast Revenue by Category')"/>
                <i class="fa fa-ellipsis-h text-muted"/>
              </div>

              <div class="d-flex gap-3">
                <div class="flex-grow-1">
                  <div class="position-relative sp_spark_box">
                    <canvas t-ref="revByCategoryChart"/>
                  </div>
                </div>

                <div style="min-width:160px;">
                  <t t-set="rows" t-value="state.rev_by_category || []"/>
                  <t t-if="!rows.length">
                    <div class="text-muted small" t-out="this._t('No data')"/>
                  </t>
                  <t t-else="">
                    <t t-foreach="rows" t-as="r" t-key="r.key">
                      <div class="d-flex justify-content-between align-items-center mb-2">
                        <div class="d-flex align-items-center gap-2">
                          <span class="sp_dot" t-att-style="'background:'+ (r.color || '#10b981')"/>
                          <span class="small fw-semibold"><t t-esc="r.name"/></span>
                        </div>
                        <div class="small fw-semibold"><t t-esc="r.value"/>M</div>
                      </div>
                    </t>
                  </t>
                </div>
              </div>

              <div class="mt-2 pt-2 border-top d-flex align-items-center gap-2 text-muted small">
                <span class="sp_iconbox"><i class="fa fa-search"/></span>
                <span t-out="this._t('System uses historical data to adjust revenue forecasts')"/>
              </div>
            </div>
          </div>

          <div class="col-12 col-lg-8">
            <div class="card sp_card p-3 h-100">
              <div class="d-flex justify-content-between align-items-center mb-2">
                <div class="fw-semibold" t-out="this._t('Purchase Suggestions (SKU)')"/>
                <button class="btn btn-success sp_btn" type="button"
                        t-on-click="onCreatePurchaseRecommendation"
                        t-att-disabled="state.creating">
                  <t t-if="state.creating"><i class="fa fa-spinner fa-spin me-1"/></t>
                  <t t-else=""><i class="fa fa-plus me-1"/></t>
                  <t t-out="this._t('Create Purchase Recommendation')"/>
                </button>
              </div>

              <div class="table-responsive">
                <table class="table table-sm align-middle mb-0">
                  <thead class="text-muted small">
                    <tr>
                      <th style="width:54px;" t-out="this._t('No.')"/>
                      <th t-out="this._t('SKU')"/>
                      <th t-out="this._t('Category')"/>
                      <th class="text-end" t-out="this._t('Demand')"/>
                      <th class="text-end" t-out="this._t('On Hand')"/>
                      <th class="text-end" t-out="this._t('Rec. Purchase')"/>
                      <th t-out="this._t('Status')"/>
                    </tr>
                  </thead>
                  <tbody>
                    <t t-set="prows" t-value="paginatedSuggestions()"/>
                    <t t-if="!prows.length">
                      <tr><td colspan="7" class="text-muted" t-out="this._t('No data')"/></tr>
                    </t>
                    <t t-else="">
                      <t t-foreach="prows" t-as="r" t-key="r.stt">
                        <tr>
                          <td><t t-esc="r.stt"/></td>
                          <td class="fw-semibold"><t t-esc="r.sku"/></td>
                          <td class="text-muted"><t t-esc="r.category"/></td>
                          <td class="text-end"><t t-esc="formatNumber(r.demand)"/></td>
                          <td class="text-end"><t t-esc="formatNumber(r.onhand)"/></td>
                          <td class="text-end"><t t-esc="formatNumber(r.plan_buy)"/></td>
                          <td>
                            <t t-if="r.status !== 'Stable' and r.status !== 'Ổn định'">
                              <span class="badge bg-warning text-dark">
                                <i class="fa fa-exclamation-triangle me-1"/> <t t-out="this._t('Out of Stock Risk')"/>
                              </span>
                            </t>
                            <t t-else="">
                              <span class="badge bg-light text-dark" t-out="this._t('Stable')"/>
                            </t>
                          </td>
                        </tr>
                      </t>
                    </t>
                  </tbody>
                </table>
              </div>

              <!-- Pagination Footer -->
              <div class="d-flex justify-content-between align-items-center mt-3 text-muted small border-top pt-2">
                <div><t t-esc="state.pagination.currentPage"/> / <t t-esc="getTotalPages()"/> <t t-out="this._t('page')"/></div>
                <div class="d-flex gap-1">
                  <button class="btn btn-sm btn-light border-0" t-on-click="() => this.changePage(state.pagination.currentPage - 1)" t-att-disabled="state.pagination.currentPage === 1">‹</button>
                  <t t-foreach="getPageNumbers()" t-as="page" t-key="page_index">
                    <button
                      t-if="page !== '...'"
                      class="btn btn-sm border-0"
                      t-att-class="state.pagination.currentPage === page ? 'btn btn-primary fw-bold' : 'btn-light'"
                      t-on-click="() => this.changePage(page)"
                    >
                      <t t-esc="page"/>
                    </button>
                    <span t-else="" class="px-2 text-muted">...</span>
                  </t>
                  <button class="btn btn-sm btn-light border-0" t-on-click="() => this.changePage(state.pagination.currentPage + 1)" t-att-disabled="state.pagination.currentPage === getTotalPages()">›</button>
                </div>
              </div>

            </div>
          </div>
        </div>

      </t>
    </div>
  </t>
</templates>
