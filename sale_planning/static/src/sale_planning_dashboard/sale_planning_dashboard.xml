<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
  <t t-name="sale_planning.Dashboard" owl="1">
    <div class="sp_wrap o_action p-3">

      <!-- TOP BAR -->
      <div class="sp_topbar d-flex justify-content-between align-items-center mb-2">
        <div>
          <div class="sp_title">Supply / Purchase Plan</div>
          <div class="sp_subtitle text-muted">
            Plan and track purchase/supply plans based on demand and production plans for the fashion industry
          </div>
        </div>

        <div class="d-flex align-items-center gap-2">
          <button class="btn btn-light sp_pill" type="button">SKU / SKU Group</button>
          <button class="btn btn-primary sp_btn" t-on-click="load" type="button">
            <i class="fa fa-refresh me-1"/> Refresh
          </button>
        </div>
      </div>

      <!-- FILTER ROW -->
      <div class="sp_filters d-flex flex-wrap gap-2 align-items-center mb-3">
        <button class="btn btn-light sp_pill" type="button">Category <i class="fa fa-angle-down ms-1"/></button>
        <button class="btn btn-light sp_pill" type="button">SKU / SKU Group <i class="fa fa-angle-down ms-1"/></button>
        <button class="btn btn-light sp_pill" type="button">All <i class="fa fa-angle-down ms-1"/></button>
        <button class="btn btn-light sp_pill" type="button">Warehouse <i class="fa fa-angle-down ms-1"/></button>
        <button class="btn btn-light sp_pill" type="button">Time <i class="fa fa-angle-down ms-1"/></button>

        <div class="ms-auto">
          <button class="btn btn-success sp_btn" type="button"
                  t-on-click="onCreateSupplyPlan"
                  t-att-disabled="state.creating">
            <t t-if="state.creating"><i class="fa fa-spinner fa-spin me-1"/></t>
            <t t-else=""><i class="fa fa-plus me-1"/></t>
            Create Supply Plan
          </button>
        </div>
      </div>

      <t t-if="state.loading">
        <div class="alert alert-info">Loading data...</div>
      </t>
      <t t-elif="state.error">
        <div class="alert alert-danger"><t t-esc="state.error"/></div>
      </t>
      <t t-else="">

        <!-- KPI CARDS -->
        <div class="row g-3 mb-3">
          <div class="col-12 col-md-3">
            <div class="card sp_card p-3 h-100">
              <div class="d-flex justify-content-between align-items-start">
                <div class="sp_card_title">Total Supply Demand</div>
                <i class="fa fa-ellipsis-h text-muted"/>
              </div>
              <div class="sp_kpi_value">
                <t t-esc="formatNumber(state.kpis.total_supply_need)"/> <span class="sp_kpi_unit">units</span>
              </div>
              <div class="sp_kpi_hint text-muted">
                +<t t-esc="state.kpis.growth_percent"/>% vs previous period
              </div>
            </div>
          </div>

          <div class="col-12 col-md-3">
            <div class="card sp_card p-3 h-100">
              <div class="d-flex justify-content-between align-items-start">
                <div class="sp_card_title">Planned Purchase</div>
                <i class="fa fa-ellipsis-h text-muted"/>
              </div>
              <div class="sp_kpi_value">
                <t t-esc="formatNumber(state.kpis.purchase_plan_qty)"/> <span class="sp_kpi_unit">units</span>
              </div>
              <div class="sp_kpi_hint text-muted">74% of demand</div>
            </div>
          </div>

          <div class="col-12 col-md-3">
            <div class="card sp_card p-3 h-100 sp_warn">
              <div class="d-flex justify-content-between align-items-start">
                <div class="sp_card_title">Out of Stock Risk</div>
                <i class="fa fa-ellipsis-h text-muted"/>
              </div>
              <div class="sp_kpi_value">
                <t t-esc="formatNumber(state.kpis.risk_sku_count)"/> <span class="sp_kpi_unit">SKUs</span>
              </div>
              <div class="sp_kpi_hint text-muted">Expected shortage in 14 days</div>
            </div>
          </div>

          <div class="col-12 col-md-3">
            <div class="card sp_card p-3 h-100">
              <div class="d-flex justify-content-between align-items-start">
                <div class="sp_card_title">Waiting for Delivery</div>
                <i class="fa fa-ellipsis-h text-muted"/>
              </div>
              <div class="sp_kpi_value">
                <t t-esc="formatNumber(state.kpis.waiting_orders)"/> <span class="sp_kpi_unit">orders</span>
              </div>
              <div class="sp_kpi_hint text-muted">Updated today</div>
            </div>
          </div>
        </div>

        <!-- MAIN ROW -->
        <div class="row g-3 mb-3">
          <div class="col-12 col-lg-8">
            <div class="card sp_card p-3 h-100">
              <div class="d-flex justify-content-between align-items-center mb-2">
                <div class="fw-semibold">Purchase Recommendations</div>
                <div class="text-muted small">Updated: <t t-esc="state.kpis.last_update"/></div>
              </div>
              <div class="position-relative sp_chart_box">
                <canvas t-ref="mainChart"/>
              </div>
            </div>
          </div>

          <div class="col-12 col-lg-4">
            <div class="card sp_card p-3 h-100">
              <div class="d-flex justify-content-between align-items-center mb-2">
                <div class="fw-semibold">Inventory Forecast</div>
                <i class="fa fa-ellipsis-h text-muted"/>
              </div>

              <div class="position-relative sp_mini_chart_box">
                <canvas t-ref="inventoryChart"/>
              </div>

              <t t-set="inv" t-value="state.inventory_forecast or {}"/>

            <div class="mt-2">
                <div class="fw-semibold">
                    <t t-esc="inv.hint and inv.hint.sku_name or '-'"/>
                </div>

                <div class="text-muted small">
                    <t t-esc="inv.hint and inv.hint.message or ''"/>
                </div>
            </div>

              <div class="mt-2 pt-2 border-top text-muted small">
                <i class="fa fa-check-circle text-success me-1"/>
                <t t-esc="inv.growth_note || ''"/>
              </div>
            </div>
          </div>
        </div>

        <!-- SECOND ROW -->
        <div class="row g-3">
          <div class="col-12 col-lg-4">
            <div class="card sp_card p-3 h-100">
              <div class="d-flex justify-content-between align-items-center mb-2">
                <div class="fw-semibold">Forecast Revenue by Category</div>
                <i class="fa fa-ellipsis-h text-muted"/>
              </div>

              <div class="d-flex gap-3">
                <div class="flex-grow-1">
                  <div class="position-relative sp_spark_box">
                    <canvas t-ref="revByCategoryChart"/>
                  </div>
                </div>

                <div style="min-width:160px;">
                  <t t-set="rows" t-value="state.rev_by_category || []"/>
                  <t t-if="!rows.length">
                    <div class="text-muted small">No data</div>
                  </t>
                  <t t-else="">
                    <t t-foreach="rows" t-as="r" t-key="r.key">
                      <div class="d-flex justify-content-between align-items-center mb-2">
                        <div class="d-flex align-items-center gap-2">
                          <span class="sp_dot" t-att-style="'background:'+ (r.color || '#10b981')"/>
                          <span class="small fw-semibold"><t t-esc="r.name"/></span>
                        </div>
                        <div class="small fw-semibold"><t t-esc="r.value"/>M</div>
                      </div>
                    </t>
                  </t>
                </div>
              </div>

              <div class="mt-2 pt-2 border-top d-flex align-items-center gap-2 text-muted small">
                <span class="sp_iconbox"><i class="fa fa-search"/></span>
                <span>System uses historical data to adjust revenue forecasts</span>
              </div>
            </div>
          </div>

          <div class="col-12 col-lg-8">
            <div class="card sp_card p-3 h-100">
              <div class="d-flex justify-content-between align-items-center mb-2">
                <div class="fw-semibold">Purchase Suggestions (SKU)</div>
                <button class="btn btn-success sp_btn" type="button"
                        t-on-click="onCreatePurchaseRecommendation"
                        t-att-disabled="state.creating">
                  <t t-if="state.creating"><i class="fa fa-spinner fa-spin me-1"/></t>
                  <t t-else=""><i class="fa fa-plus me-1"/></t>
                  Create Purchase Recommendation
                </button>
              </div>

              <div class="table-responsive">
                <table class="table table-sm align-middle mb-0">
                  <thead class="text-muted small">
                    <tr>
                      <th style="width:54px;">No.</th>
                      <th>SKU</th>
                      <th>Category</th>
                      <th class="text-end">Demand</th>
                      <th class="text-end">On Hand</th>
                      <th class="text-end">Rec. Purchase</th>
                      <th>Status</th>
                    </tr>
                  </thead>
                  <tbody>
                    <t t-if="!state.order_suggestions.length">
                      <tr><td colspan="7" class="text-muted">No data</td></tr>
                    </t>
                    <t t-else="">
                      <t t-foreach="state.order_suggestions" t-as="r" t-key="r.stt">
                        <tr>
                          <td><t t-esc="r.stt"/></td>
                          <td class="fw-semibold"><t t-esc="r.sku"/></td>
                          <td class="text-muted"><t t-esc="r.category"/></td>
                          <td class="text-end"><t t-esc="formatNumber(r.demand)"/></td>
                          <td class="text-end"><t t-esc="formatNumber(r.onhand)"/></td>
                          <td class="text-end"><t t-esc="formatNumber(r.plan_buy)"/></td>
                          <td>
                            <t t-if="r.status !== 'Stable' and r.status !== 'Ổn định'">
                              <span class="badge bg-warning text-dark">
                                <i class="fa fa-exclamation-triangle me-1"/> Out of Stock Risk
                              </span>
                            </t>
                            <t t-else="">
                              <span class="badge bg-light text-dark">Stable</span>
                            </t>
                          </td>
                        </tr>
                      </t>
                    </t>
                  </tbody>
                </table>
              </div>

            </div>
          </div>
        </div>

      </t>
    </div>
  </t>
</templates>
