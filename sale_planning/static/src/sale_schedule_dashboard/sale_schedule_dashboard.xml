<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

  <t t-name="sale_planning.SaleScheduleDashboard" owl="1">
    <div class="ssd_wrap o_action p-3">

      <!-- TOP BAR -->
      <div class="ssd_top d-flex justify-content-between align-items-center mb-2">
        <div class="d-flex align-items-center gap-2">
          <div class="ssd_logo"><i class="fa fa-repeat"/></div>
          <div class="ssd_title" t-out="this._t('SALE SCHEDULING')"/>
        </div>

        <div class="d-flex align-items-center gap-2">
          <!-- Category Filter -->
          <select class="form-select ssd_pill w-auto" t-on-change="(ev) => this.onFilterChange('category_id', ev.target.value)">
              <option value=""><t t-out="this._t('Category')"/>: <t t-out="this._t('All')"/></option>
              <t t-foreach="state.categories" t-as="cat" t-key="cat.id">
                  <option t-att-value="cat.id" t-att-selected="state.filters.category_id == cat.id"><t t-esc="cat.name"/></option>
              </t>
          </select>

          <!-- Warehouse Filter -->
          <select class="form-select ssd_pill w-auto" t-on-change="(ev) => this.onFilterChange('warehouse_id', ev.target.value)">
              <option value=""><t t-out="this._t('Branch')"/>: <t t-out="this._t('All')"/></option>
              <t t-foreach="state.warehouses" t-as="wh" t-key="wh.id">
                  <option t-att-value="wh.id" t-att-selected="state.filters.warehouse_id == wh.id"><t t-esc="wh.name"/></option>
              </t>
          </select>

          <button class="btn btn-primary ssd_iconbtn"><i class="fa fa-cog"/></button>
          <span class="ssd_avatar"/>
        </div>
      </div>

      <!-- SUB HEADER -->
      <div class="ssd_sub card p-3 mb-3">
        <div class="d-flex justify-content-between align-items-center">
          <div class="ssd_tabs">
            <span class="fw-semibold" t-out="this._t('Fashion Industry')"/>
            <span class="text-muted">· <t t-out="this._t('By SKU')"/> · <t t-out="this._t('By Campaign')"/> · <t t-out="this._t('By Time')"/></span>
          </div>
          <div class="d-flex gap-2">
            <button class="btn btn-light ssd_btn" t-on-click="() => this.openAction('action_open_sale_orders')">
              <i class="fa fa-list me-1"/> <t t-out="this._t('Open Sales Orders')"/>
            </button>
            <button class="btn btn-success ssd_btn" t-on-click="() => this.openAction('action_open_inventory')">
              <i class="fa fa-cubes me-1"/> <t t-out="this._t('View Inventory')"/>
            </button>
          </div>
        </div>
      </div>

      <t t-if="state.loading">
        <div class="alert alert-info" t-out="this._t('Loading data...')"/>
      </t>
      <t t-elif="state.error">
        <div class="alert alert-danger"><t t-esc="state.error"/></div>
      </t>
      <t t-else="">

        <!-- KPI ROW -->
        <div class="row g-3 mb-3">
          <div class="col-12 col-md-3">
            <div class="card ssd_card p-3">
              <div class="d-flex align-items-center gap-2">
                <div class="ssd_kpi_icon ssd_i_blue"><i class="fa fa-calendar-plus-o"/></div>
                <div>
                  <div class="ssd_kpi_big"><t t-esc="state.kpis.wave_count"/> <t t-out="this._t('waves')"/></div>
                  <div class="text-muted small"><t t-out="this._t('Main SKU:')"/> <t t-esc="state.kpis.main_sku"/></div>
                </div>
              </div>
            </div>
          </div>

          <div class="col-12 col-md-3">
            <div class="card ssd_card p-3">
              <div class="d-flex align-items-center gap-2">
                <div class="ssd_kpi_icon ssd_i_green"><i class="fa fa-line-chart"/></div>
                <div>
                  <div class="ssd_kpi_big">
                    <t t-esc="formatMoneyVND(state.kpis.revenue)"/>
                  </div>
                  <div class="text-success small">+<t t-esc="state.kpis.revenue_delta"/>% <t t-out="this._t('vs plan')"/></div>
                </div>
              </div>
            </div>
          </div>

          <div class="col-12 col-md-3">
            <div class="card ssd_card p-3">
              <div class="d-flex align-items-center gap-2">
                <div class="ssd_kpi_icon ssd_i_red"><i class="fa fa-exclamation-triangle"/></div>
                <div>
                  <div class="ssd_kpi_big" t-out="this._t('Schedule Risk')"/>
                  <div class="text-muted small"><t t-esc="state.kpis.risk_sku_count"/> <t t-out="this._t('SKUs at risk of shortage')"/></div>
                </div>
              </div>
            </div>
          </div>

          <div class="col-12 col-md-3">
            <div class="card ssd_card p-3">
              <div class="d-flex justify-content-between align-items-start">
                <div class="d-flex align-items-center gap-2">
                  <div class="ssd_kpi_icon ssd_i_yellow"><i class="fa fa-bell"/></div>
                  <div>
                    <div class="ssd_kpi_big" t-out="this._t('Schedules Needing Adjust.')"/>
                    <div class="text-muted small"><t t-esc="state.kpis.need_review_count"/> <t t-out="this._t('schedules to review')"/></div>
                  </div>
                </div>
                <i class="fa fa-ellipsis-h text-muted"/>
              </div>
            </div>
          </div>
        </div>

        <!-- MAIN GRID -->
        <div class="row g-3">
          <!-- LEFT: TIMELINE -->
          <div class="col-12 col-lg-8">
            <div class="card ssd_card p-3">
              <div class="d-flex justify-content-between align-items-center mb-2">
                <div class="fw-semibold" t-out="this._t('Sale Schedule Timeline by SKU')"/>
                <div class="d-flex gap-2">
                  <button class="btn btn-light ssd_pill" t-on-click="() => this.setViewMode('timeline')">
                    <i class="fa fa-align-left me-1"/> <t t-out="this._t('Timeline')"/>
                  </button>
                  <button class="btn btn-light ssd_pill" t-on-click="() => this.setViewMode('calendar')">
                    <i class="fa fa-calendar me-1"/> <t t-out="this._t('Calendar')"/>
                  </button>
                </div>
              </div>

              <!-- GRID HEADER -->
              <div class="ssd_grid_header">
                <div class="ssd_grid_left_head text-muted small">Mon, 01 Apr</div>
                <div class="ssd_grid_cols">
                  <t t-foreach="state.timeline.cols" t-as="c" t-key="c">
                    <div class="ssd_col_head"><t t-esc="c"/></div>
                  </t>
                </div>
              </div>

              <!-- GRID BODY -->
              <div class="ssd_grid_body">
                <t t-foreach="state.timeline.rows" t-as="r" t-key="r.key">
                  <div class="ssd_row" t-att-class="r.key === state.active_row_key ? 'is_active' : ''">
                    <div class="ssd_row_left" t-on-click="() => this.selectRow(r)">
                      <t t-if="r.image_url">
                        <img class="ssd_thumb" t-att-src="r.image_url" t-att-alt="r.sku"/>
                      </t>
                      <t t-else="">
                        <div class="ssd_thumb"/>
                      </t>
                      <div>
                        <div class="fw-semibold"><t t-esc="r.sku"/> – <t t-esc="r.campaign"/></div>
                        <div class="text-muted small">
                          <i class="fa fa-cube me-1"/> <t t-esc="r.stock"/> ·
                          <t t-esc="formatMoneyVND(r.target)"/>
                        </div>
                      </div>
                    </div>

                    <div class="ssd_row_right">
                      <div class="ssd_row_track">
                        <t t-foreach="r.bars" t-as="b" t-key="b.label">
                          <div class="ssd_bar"
                               t-att-style="'grid-column:' + (b.start + 1) + ' / span ' + b.span + ';'"
                               t-att-class="'c_' + b.color">
                            <span><t t-esc="b.label"/></span>
                          </div>
                        </t>
                      </div>
                    </div>
                  </div>
                </t>
                <t t-if="!state.timeline.rows.length">
                  <div class="text-muted small py-3" t-out="this._t('No schedule data for current filters.')"/>
                </t>
              </div>
            </div>

            <!-- BOTTOM CARDS -->
            <div class="row g-3 mt-1">
              <div class="col-12 col-lg-7">
                <div class="card ssd_card p-3 h-100">
                  <div class="d-flex justify-content-between align-items-center mb-2">
                    <div class="fw-semibold" t-out="this._t('Performance Tracking by Schedule')"/>
                    <i class="fa fa-ellipsis-h text-muted"/>
                  </div>
                  <div class="d-flex align-items-center gap-3">
                    <t t-if="state.performance.image_url">
                      <img class="ssd_thumb_big" t-att-src="state.performance.image_url" t-att-alt="state.performance.title"/>
                    </t>
                    <t t-else="">
                      <div class="ssd_thumb_big"/>
                    </t>
                    <div class="flex-grow-1">
                      <div class="fw-semibold"><t t-esc="state.performance.title"/></div>
                      <div class="text-muted small">
                        <t t-out="this._t('Reached')"/> <t t-esc="state.performance.progress_percent"/>% <t t-out="this._t('of plan (after')"/> <t t-esc="state.performance.days"/> <t t-out="this._t('days)')"/>
                      </div>
                      <div class="ssd_progress mt-2">
                        <div class="ssd_progress_bar" t-att-style="'width:' + state.performance.progress_percent + '%'"/>
                      </div>
                    </div>
                  </div>
                </div>
              </div>

              <div class="col-12 col-lg-5">
                <div class="card ssd_card p-3 h-100">
                  <div class="d-flex justify-content-between align-items-center mb-2">
                    <div class="fw-semibold" t-out="this._t('Risk Alerts')"/>
                    <i class="fa fa-ellipsis-h text-muted"/>
                  </div>

                  <div class="d-flex flex-column gap-2">
                    <t t-foreach="state.risk_alerts" t-as="a" t-key="a.key">
                      <div class="ssd_alert">
                        <div class="ssd_alert_icon"><i class="fa fa-warning"/></div>
                        <div class="flex-grow-1">
                          <div class="fw-semibold"><t t-esc="a.sku"/></div>
                          <div class="text-muted small"><t t-esc="a.message"/></div>
                        </div>
                        <i t-att-class="a.trend === 'up' ? 'fa fa-arrow-up text-success' : 'fa fa-arrow-down text-danger'"/>
                      </div>
                    </t>
                    <t t-if="!state.risk_alerts.length">
                      <div class="text-muted small" t-out="this._t('No risk alerts')"/>
                    </t>
                  </div>
                </div>
              </div>
            </div>

          </div>

          <!-- RIGHT: DETAIL -->
          <div class="col-12 col-lg-4">
            <div class="card ssd_card p-3 mb-3">
              <div class="d-flex justify-content-between align-items-center mb-2">
                <div class="fw-semibold" t-out="this._t('Schedule Details')"/>
                <i class="fa fa-ellipsis-h text-muted"/>
              </div>

              <div class="d-flex gap-3">
                <t t-if="state.selected.image_url">
                  <img class="ssd_thumb_big" t-att-src="state.selected.image_url" t-att-alt="state.selected.sku"/>
                </t>
                <t t-else="">
                  <div class="ssd_thumb_big"/>
                </t>
                <div>
                  <div class="fw-semibold fs-5"><t t-esc="state.selected.sku"/></div>
                  <div class="text-muted"><t t-esc="state.selected.campaign"/></div>
                  <div class="text-muted small mt-1">SKU: <t t-esc="state.selected.sku_code"/></div>
                </div>
              </div>

              <div class="mt-3 text-muted">Time: <span class="fw-semibold text-dark">
                <t t-esc="state.selected.date_from"/> – <t t-esc="state.selected.date_to"/>
              </span></div>

              <div class="d-flex gap-2 mt-2">
                <t t-foreach="state.selected.badges || []" t-as="badge" t-key="badge.label">
                  <span class="badge" t-att-class="badge.className"><t t-esc="badge.label"/></span>
                </t>
              </div>

              <div class="mt-3 pt-3 border-top">
                <div class="fw-semibold mb-2" t-out="this._t('Linked to Inventory')"/>
                <div class="text-muted"><t t-out="this._t('Current on hand:')"/> <span class="fw-semibold text-dark"><t t-esc="state.inventory_link.onhand"/></span> <t t-out="this._t('units')"/></div>
                <div class="text-muted"><t t-out="this._t('Expected daily sales:')"/> <span class="fw-semibold text-dark"><t t-esc="state.inventory_link.daily_sell"/></span> <t t-out="this._t('units')"/></div>
                <div class="text-muted"><t t-out="this._t('Expected out of stock date:')"/> <span class="fw-semibold text-dark"><t t-esc="state.inventory_link.out_of_stock_date"/></span>
                  <span class="text-muted"> <t t-out="'(' + this._t('in') + ' '"/> <t t-esc="state.inventory_link.out_of_stock_in_days"/> <t t-out="this._t('days)')"/></span>
                </div>
              </div>

              <div class="d-flex gap-2 mt-3">
                <button class="btn btn-success flex-fill" t-on-click="() => this.openAction('action_open_sale_orders')" t-out="this._t('Open Sales Orders')"/>
                <button class="btn btn-light flex-fill" t-on-click="() => this.openAction('action_open_product')" t-out="this._t('View Product')"/>
                <button class="btn btn-light flex-fill" t-on-click="() => this.openAction('action_open_inventory')" t-out="this._t('View Inventory')"/>
              </div>
            </div>

          </div>
        </div>

      </t>
    </div>
  </t>

</templates>
