<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

  <t t-name="sale_planning.DashboardProgress" owl="1">
    <div class="sp_progress o_action p-3">

      <!-- HEADER -->
      <div class="sp_header mb-3 d-flex justify-content-between align-items-center">
        <div class="d-flex align-items-center gap-2">
          <div class="sp_brand" t-out="this._t('EXECUTION PROGRESS TRACKING')"/>
        </div>

        <div class="d-flex align-items-center gap-2">
          <!-- Category Filter -->
          <select class="form-select sp_pill w-auto" t-on-change="(ev) => this.onFilterChange('category_id', ev.target.value)">
              <option value=""><t t-out="this._t('Category')"/>: <t t-out="this._t('All')"/></option>
              <t t-foreach="state.categories" t-as="cat" t-key="cat.id">
                  <option t-att-value="cat.id" t-att-selected="state.filters.category_id == cat.id"><t t-esc="cat.name"/></option>
              </t>
          </select>

          <!-- Warehouse Filter -->
          <select class="form-select sp_pill w-auto" t-on-change="(ev) => this.onFilterChange('warehouse_id', ev.target.value)">
              <option value=""><t t-out="this._t('Warehouse')"/>: <t t-out="this._t('All')"/></option>
              <t t-foreach="state.warehouses" t-as="wh" t-key="wh.id">
                  <option t-att-value="wh.id" t-att-selected="state.filters.warehouse_id == wh.id"><t t-esc="wh.name"/></option>
              </t>
          </select>

          <!-- Time Filter -->
          <select class="form-select sp_pill w-auto" t-on-change="(ev) => this.onFilterChange('view_mode', ev.target.value)">
              <t t-foreach="state.time_options" t-as="opt" t-key="opt.id">
                  <option t-att-value="opt.id" t-att-selected="state.filters.view_mode == opt.id"><t t-esc="opt.name"/></option>
              </t>
          </select>
        </div>
      </div>

      <div class="sp_subheader mb-3 d-flex justify-content-between align-items-center">
        <div class="text-muted">
          <t t-out="this._t('Executive Dashboard')"/> · <b><t t-out="this._t('Fashion Industry')"/></b> · <t t-out="this._t('By Time')"/>
        </div>
      </div>

      <t t-if="state.loading">
        <div class="alert alert-info" t-out="this._t('Loading data...')"/>
      </t>
      <t t-elif="state.error">
        <div class="alert alert-danger"><t t-esc="state.error"/></div>
      </t>
      <t t-else="">

        <!-- KPI ROW -->
        <div class="row g-3 mb-3">
          <div class="col-12 col-lg-3">
            <div class="card sp_kpi sp_kpi_yellow p-3">
              <div class="sp_kpi_title"><t t-out="this._t('Achieved')"/> <b><t t-esc="state.kpis.progress_percent"/>%</b> <t t-out="this._t('of plan')"/></div>
              <div class="sp_kpi_hint text-muted">—</div>
            </div>
          </div>

          <div class="col-12 col-lg-3">
            <div class="card sp_kpi sp_kpi_red p-3">
              <div class="sp_kpi_title" t-out="this._t('SKUs at risk of shortage')"/>
              <div class="sp_kpi_big"><t t-esc="state.kpis.late_sku_count"/> <t t-out="this._t('SKUs')"/></div>
              <div class="text-muted small"><t t-esc="state.kpis.late_sku_names"/></div>
            </div>
          </div>

          <div class="col-12 col-lg-3">
            <div class="card sp_kpi sp_kpi_green p-3">
              <div class="sp_kpi_title" t-out="this._t('SKUs on / above plan')"/>
              <div class="sp_kpi_big"><t t-esc="state.kpis.ontrack_sku_count"/> <t t-out="this._t('SKUs')"/></div>
              <div class="text-muted small"><t t-esc="state.kpis.ontrack_sku_names"/></div>
            </div>
          </div>

          <div class="col-12 col-lg-3">
            <div class="card sp_kpi sp_kpi_pink p-3">
              <div class="sp_kpi_title" t-out="this._t('Alerts needing handling')"/>
              <div class="sp_kpi_big"><t t-esc="state.kpis.critical_count"/></div>
              <div class="text-muted small"><t t-esc="state.kpis.critical_hint"/></div>
            </div>
          </div>
        </div>

        <!-- MAIN CHART + RISK -->
        <div class="row g-3 mb-3">
          <div class="col-12 col-lg-8">
            <div class="card p-3 sp_panel">
              <div class="d-flex justify-content-between align-items-center mb-2">
                <div class="sp_panel_title" t-out="this._t('Overall Execution Progress')"/>
                <div class="d-flex align-items-center gap-3 text-muted small">
                  <span><i class="fa fa-square me-1"/><t t-out="this._t('Planned')"/></span>
                  <span><i class="fa fa-square me-1"/><t t-out="this._t('Actual')"/></span>
                </div>
              </div>

              <div class="position-relative" style="height: 290px;">
                <canvas t-ref="overallChart"/>
              </div>
            </div>
          </div>

          <div class="col-12 col-lg-4">
            <div class="card p-3 sp_panel h-100">
              <div class="d-flex justify-content-between align-items-center mb-2">
                <div class="sp_panel_title" t-out="this._t('Alerts &amp; Risks')"/>
                <button class="btn btn-sm btn-light rounded-circle" type="button" style="width:32px;height:32px;">
                  <i class="fa fa-ellipsis-h"/>
                </button>
              </div>

              <div class="sp_risk_list">
                <t t-foreach="state.risks" t-as="r" t-key="r.name">
                  <div class="sp_risk_item d-flex gap-2 align-items-start">
                    <div class="sp_risk_badge" t-att-class="r.level == 'high' ? 'sp_risk_high' : 'sp_risk_med'">
                      <i class="fa fa-exclamation-triangle"/>
                    </div>
                    <div class="flex-grow-1">
                      <div class="fw-semibold"><t t-esc="r.name"/></div>
                      <div class="text-muted small"><t t-esc="r.hint"/></div>
                    </div>
                  </div>
                </t>
              </div>

              <div class="mt-auto pt-2">
                <button class="btn sp_pill w-100" type="button">
                  <i class="fa fa-tag me-1"/> <t t-out="this._t('See All')"/> <i class="fa fa-angle-down ms-1"/>
                </button>
              </div>
            </div>
          </div>
        </div>

        <!-- SKU CARDS + HISTORY -->
        <div class="row g-3">
          <div class="col-12 col-lg-8">
            <div class="card p-3 sp_panel">
              <div class="d-flex justify-content-between align-items-center mb-2">
                <div class="sp_panel_title" t-out="this._t('Progress by SKU / Order')"/>
                <button class="btn btn-sm btn-light rounded-circle" type="button" style="width:32px;height:32px;">
                  <i class="fa fa-ellipsis-h"/>
                </button>
              </div>

              <div class="row g-3">
                <t t-foreach="state.sku_cards" t-as="c" t-key="c.key">
                  <div class="col-12 col-md-4">
                    <div class="sp_sku_card p-3">
                      <div class="d-flex justify-content-between align-items-center mb-2">
                        <div class="fw-semibold"><t t-esc="c.name"/></div>
                        <button class="btn btn-sm btn-light rounded-circle" type="button" style="width:28px;height:28px;">
                          <i class="fa fa-ellipsis-h"/>
                        </button>
                      </div>

                      <div class="d-flex justify-content-between align-items-end mb-2">
                        <div t-att-class="c.status_type == 'bad' ? 'text-danger fw-semibold' : 'text-success fw-semibold'">
                          <t t-esc="c.status"/>
                        </div>
                        <div class="fs-4 fw-bold"><t t-esc="c.percent"/>%</div>
                      </div>

                      <t t-if="c.revenue">
                        <div class="text-muted small mb-1">
                          <i class="fa fa-line-chart me-1"/>
                          <t t-esc="fmtMoney(c.revenue)"/> đ
                        </div>
                      </t>

                      <t t-if="c.reasons">
                        <div class="text-muted small">
                          <t t-foreach="c.reasons" t-as="rr" t-key="rr">
                            <div>• <t t-esc="rr"/></div>
                          </t>
                        </div>
                      </t>

                      <t t-if="c.tags">
                        <div class="mt-2 d-flex gap-2 flex-wrap">
                          <t t-foreach="c.tags" t-as="tg" t-key="tg">
                            <span class="badge bg-light text-dark"><t t-esc="tg"/></span>
                          </t>
                        </div>
                      </t>
                    </div>
                  </div>
                </t>
              </div>
            </div>
          </div>

          <div class="col-12 col-lg-4">
            <div class="card p-3 sp_panel h-100">
              <div class="d-flex justify-content-between align-items-center mb-2">
                <div class="sp_panel_title" t-out="this._t('Execution History &amp; Trends')"/>
                <button class="btn sp_pill" type="button"><t t-out="this._t('See All')"/> <i class="fa fa-angle-down ms-1"/></button>
              </div>

              <div class="position-relative mb-2" style="height: 170px;">
                <canvas t-ref="historyChart"/>
              </div>

              <div class="sp_note p-2">
                <i class="fa fa-pencil me-1"/>
                <t t-esc="state.history.note"/>
              </div>
            </div>
          </div>
        </div>

      </t>
    </div>
  </t>

</templates>
