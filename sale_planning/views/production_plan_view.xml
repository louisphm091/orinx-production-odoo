<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_production_plan_tree" model="ir.ui.view">
        <field name="name">production.plan.tree</field>
        <field name="model">production.plan</field>
        <field name="arch" type="xml">
            <list string="Dự báo &amp; Lập kế hoạch sản xuất">
                <field name="name"/>
                <field name="date"/>
                <field name="user_id"/>
                <field name="state" column_invisible="True"/>
            </list>
        </field>
    </record>

    <record id="view_production_plan_form" model="ir.ui.view">
        <field name="name">production.plan.form</field>
        <field name="model">production.plan</field>
        <field name="arch" type="xml">
            <form string="Kế hoạch sản xuất" create="true" edit="true" class="o_full_screen">
                <group invisible="1">
                    <field name="name"/>
                    <field name="date"/>
                    <field name="user_id"/>
                    <field name="state"/>
                </group>
                    <field name="id" widget="production_plan_dashboard_widget"/>
            </form>
        </field>
    </record>

    <record id="action_production_plan" model="ir.actions.act_window">
        <field name="name">Lập kế hoạch sản xuất</field>
        <field name="res_model">production.plan</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Tạo kế hoạch sản xuất đầu tiên của bạn!
            </p>
        </field>
    </record>
</odoo>
